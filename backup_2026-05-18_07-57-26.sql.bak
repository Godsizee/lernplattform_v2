            "D": "Umgliederung von Anlagegütern in das Umlaufvermögen",
            "E": "Umgliederung von Fremdwährungen in Hauswährung"
        },
        "correct": [
            "A",
            "B",
            "C"
        ],
        "link": "\\/module?id=s4f10"
    }
]', 'quiz', 'published', 75, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
