INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l89n7amw0lsj17d9dn5', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Werteveränderungen in der Bilanz', '
            <h3>Grundregel</h3>
            <p>Jeder Geschäftsfall wirkt sich auf mindestens zwei Posten der Bilanz aus (Doppelte Buchführung). Dabei bleibt das Gleichgewicht der Bilanz (Aktiva = Passiva) stets erhalten. Es gibt vier Grundfälle der Werteveränderung.</p>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
                
                <!-- 1. AKTIVTAUSCH -->
                <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db;">
                    <h4 style="margin-top:0; color: #2980b9;">1. Aktivtausch</h4>
                    <p><strong>Was passiert?</strong> Ein Aktivposten nimmt zu (+), ein anderer nimmt ab (-).</p>
                    <p><strong>Bilanzsumme:</strong> Bleibt gleich.</p>
                    <p><strong>Beispiel:</strong><br>
                    Kauf einer EDV-Anlage gegen Banküberweisung (2.000 €).</p>
                    <ul style="font-size: 0.9em; color: #555;">
                        <li>BGA (Betriebsausstattung) + 2.000 €</li>
                        <li>Bankguthaben - 2.000 €</li>
                    </ul>
                </div>

                <!-- 2. PASSIVTAUSCH -->
                <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12;">
                    <h4 style="margin-top:0; color: #d35400;">2. Passivtausch</h4>
                    <p><strong>Was passiert?</strong> Ein Passivposten nimmt zu (+), ein anderer nimmt ab (-).</p>
                    <p><strong>Bilanzsumme:</strong> Bleibt gleich.</p>
                    <p><strong>Beispiel:</strong><br>
                    Eine kurzfristige Lieferantenschuld wird in ein langfristiges Darlehen umgewandelt (3.000 €).</p>
                    <ul style="font-size: 0.9em; color: #555;">
                        <li>Verbindlichkeiten (Kurzfr.) - 3.000 €</li>
                        <li>Darlehen (Langfr.) + 3.000 €</li>
                    </ul>
                </div>

                <!-- 3. AKTIV-PASSIV-MEHRUNG -->
                <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f0fdf4; border-left: 4px solid #2ecc71;">
                    <h4 style="margin-top:0; color: #27ae60;">3. Aktiv-Passiv-Mehrung</h4>
                    <p><strong>Was passiert?</strong> Ein Aktivposten nimmt zu (+), ein Passivposten nimmt zu (+).</p>
                    <p><strong>Bilanzsumme:</strong> Erhöht sich (Bilanzverlängerung).</p>
                    <p><strong>Beispiel:</strong><br>
                    Kauf von Rohstoffen auf Ziel (4.000 €).</p>
                    <ul style="font-size: 0.9em; color: #555;">
                        <li>Rohstoffe (Aktiv) + 4.000 €</li>
                        <li>Verbindlichkeiten (Passiv) + 4.000 €</li>
                    </ul>
                </div>

                <!-- 4. AKTIV-PASSIV-MINDERUNG -->
                <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fef2f2; border-left: 4px solid #e74c3c;">
                    <h4 style="margin-top:0; color: #c0392b;">4. Aktiv-Passiv-Minderung</h4>
                    <p><strong>Was passiert?</strong> Ein Aktivposten nimmt ab (-), ein Passivposten nimmt ab (-).</p>
                    <p><strong>Bilanzsumme:</strong> Vermindert sich (Bilanzverkürzung).</p>
                    <p><strong>Beispiel:</strong><br>
                    Ausgleich einer Lieferantenrechnung durch Banküberweisung (1.500 €).</p>
                    <ul style="font-size: 0.9em; color: #555;">
                        <li>Bankguthaben (Aktiv) - 1.500 €</li>
                        <li>Verbindlichkeiten (Passiv) - 1.500 €</li>
                    </ul>
                </div>
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>Checkliste zur Analyse von Geschäftsfällen</h3>
            <p>Stellen Sie sich bei jeder Buchung folgende vier Fragen, um Fehler zu vermeiden:</p>
            <ol style="background: #e8f4f8; padding: 1.5rem; border-radius: 8px; font-weight: bold; color: #2c3e50;">
                <li>Welche Posten der Bilanz werden berührt? (z.B. Kasse, Verbindlichkeiten)</li>
                <li>Handelt es sich um Aktiv- oder Passivposten?</li>
                <li>Wie wirkt sich der Geschäftsfall aus (Zunahme oder Abnahme)?</li>
                <li>Um welche der vier Arten der Wertveränderung handelt es sich?</li>
            </ol>
        ', '', 'article', 'published', 26, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l8b8rxd1ngsacgdwqxo', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4500 - Kapitel 9', '', '[
