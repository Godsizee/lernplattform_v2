        "chapter": "Kapitel 7",
        "question": "Welche der folgenden Aktivitäten können Sie über das Customizing ausführen?",
        "type": "checkbox",
        "options": {
            "A": "Customizing-Dokumentation lesen",
            "B": "Customizing-Aktivitätsstatus prüfen",
            "C": "Einkaufsbelege anlegen"
