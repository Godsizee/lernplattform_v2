INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lxf9p89pybnjdajhfdw', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Buchen auf Erfolgskonten (GuV)', '
            <h3>1. Aufwendungen und Erträge</h3>
            <p>Bisher haben wir nur Bestandsveränderungen (Aktivtausch, Passivtausch) betrachtet, die den Gewinn nicht beeinflussen. Im Unternehmensalltag entstehen jedoch ständig Werteverzehre und Wertezuwächse, die das <strong>Eigenkapital</strong> verändern.</p>
            
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 10px; padding: 10px; background: #ffebee; border-left: 4px solid #c0392b;">
                    <strong>Aufwendungen (Werteverzehr)</strong><br>
                    Vermindern das Eigenkapital.<br>
                    <em>Beispiele: Löhne, Gehälter, Miete, Verbrauch von Rohstoffen, Zinsaufwendungen.</em>
                </li>
                <li style="padding: 10px; background: #e8f5e9; border-left: 4px solid #27ae60;">
                    <strong>Erträge (Wertezuwachs)</strong><br>
                    Erhöhen das Eigenkapital.<br>
                    <em>Beispiele: Umsatzerlöse (Verkauf von Produkten), Zinserträge, Mieteinnahmen.</em>
                </li>
            </ul>

            <p>Da man diese Vorgänge nicht direkt im Eigenkapitalkonto buchen möchte (Unübersichtlichkeit), werden spezielle Unterkonten des Eigenkapitals eingerichtet: <strong>Die Erfolgskonten</strong>.</p>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>2. Buchungsregeln für Erfolgskonten</h3>
            
            <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                <!-- AUFWANDSKONTO -->
                <div style="flex: 1; min-width: 300px;">
                    <h4 style="color: #c0392b; border-bottom: 2px solid #c0392b; padding-bottom: 5px;">Aufwandskonten</h4>
                    <p>Verhalten sich wie Aktivkonten (Mindern das EK, wirken wie Abgänge im Passivkonto -> also im Soll gebucht).</p>
                    <table style="width: 100%; border: 1px solid #ccc; background: #f9f9f9; font-size: 0.9em;">
                        <tr>
                            <td style="width: 50%; border-right: 1px solid #ccc; padding: 10px; vertical-align: top;">
                                <strong>Soll</strong><br>
                                <span style="color: #c0392b; font-weight: bold;">+ Aufwendungen</span><br>
                                (Löhne, Miete, etc.)
                            </td>
                            <td style="width: 50%; padding: 10px; vertical-align: top;">
                                <strong>Haben</strong><br>
                                <span style="color: #777;">- Stornierungen</span><br>
                                <span style="color: #000; font-weight: bold;">= Saldo (GuV)</span>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- ERTRAGSKONTO -->
                <div style="flex: 1; min-width: 300px;">
                    <h4 style="color: #27ae60; border-bottom: 2px solid #27ae60; padding-bottom: 5px;">Ertragskonten</h4>
                    <p>Verhalten sich wie Passivkonten (Erhöhen das EK -> also im Haben gebucht).</p>
                    <table style="width: 100%; border: 1px solid #ccc; background: #f9f9f9; font-size: 0.9em;">
                        <tr>
                            <td style="width: 50%; border-right: 1px solid #ccc; padding: 10px; vertical-align: top;">
                                <strong>Soll</strong><br>
                                <span style="color: #777;">- Stornierungen</span><br>
                                <span style="color: #000; font-weight: bold;">= Saldo (GuV)</span>
                            </td>
                            <td style="width: 50%; padding: 10px; vertical-align: top;">
                                <strong>Haben</strong><br>
                                <span style="color: #27ae60; font-weight: bold;">+ Erträge</span><br>
                                (Umsatzerlöse, Zinsen)
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <div style="margin-top: 1.5rem;">
                <strong>Beispielbuchungen:</strong><br>
                <code>Löhne an Bank 35.000 €</code> (Aufwand im Soll)<br>
                <code>Bank an Zinserträge 700 €</code> (Ertrag im Haben)
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>3. Abschluss über das Gewinn- und Verlustkonto (GuV)</h3>
            <p>Am Jahresende werden die Erfolgskonten nicht direkt in die Bilanz, sondern zunächst in das <strong>Gewinn- und Verlustkonto (GuV)</strong> abgeschlossen.</p>

            <div style="border: 2px solid #333; padding: 1rem; background: #fff; margin-bottom: 1rem;">
                <h4 style="text-align: center; margin-top:0;">GuV-Konto (Sammelkonto)</h4>
                <div style="display: flex;">
                    <div style="flex:1; border-right: 1px solid #ccc; padding: 10px;">
                        <strong>Soll (Aufwendungen)</strong><br>
                        - Materialaufwand<br>
                        - Personalaufwand<br>
                        - Abschreibungen<br>
                        - Mietaufwand<br>
                        <hr>
                        <span style="color: #27ae60; font-weight: bold;">Gewinn (Saldo)</span>
                    </div>
                    <div style="flex:1; padding: 10px;">
                        <strong>Haben (Erträge)</strong><br>
                        - Umsatzerlöse<br>
                        - Zinserträge<br>
                        - Mieterträge<br>
                        <br>
                        <hr>
                        <span style="color: #c0392b; font-weight: bold;">Verlust (Saldo)</span>
                    </div>
                </div>
            </div>

            <p><strong>Der Abschluss des GuV-Kontos:</strong><br>
            Der Saldo des GuV-Kontos zeigt den Unternehmenserfolg. Dieser Saldo wird schließlich auf das <strong>Eigenkapitalkonto</strong> übertragen.</p>
            
            <ul>
                <li><strong>Bei Gewinn:</strong> <code>GuV an Eigenkapital</code> (Eigenkapital mehrt sich im Haben)</li>
                <li><strong>Bei Verlust:</strong> <code>Eigenkapital an GuV</code> (Eigenkapital mindert sich im Soll)</li>
            </ul>

            <div style="background: #e0f7fa; padding: 1rem; border-left: 4px solid #00acc1;">
                <strong>Zusammenfassung:</strong><br>
                Aufwendungen -> GuV (Soll)<br>
                Erträge -> GuV (Haben)<br>
                Saldo GuV (Gewinn) -> Eigenkapital (Haben)<br>
                Saldo Eigenkapital -> Schlussbilanz (Passiva)
            </div>
        ', '', 'article', 'published', 28, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lxpz0ugl44a1dydinx9', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'DQL: Tabellen verknüpfen (INNER JOIN)', '<h3>1. Das Problem mit verteilten Daten</h3>
<p>Dank der Normalisierung haben wir unsere Daten sauber auf mehrere Tabellen aufgeteilt (z.B. <code>kunden</code> und <code>bestellungen</code>). Wenn wir nun aber eine Rechnungsübersicht drucken wollen, brauchen wir den Namen des Kunden (aus Tabelle A) und den Rechnungsbetrag (aus Tabelle B) in <strong>einem einzigen Ergebnis</strong>.</p>

<p>Hier kommen die <strong>JOINs</strong> (Verbundoperationen) ins Spiel!</p>

<h3>2. Der INNER JOIN</h3>
<p>Der <code>INNER JOIN</code> ist der absolute Standard-Join. Er bildet die mathematische <strong>Schnittmenge</strong> zweier Tabellen. Er liefert nur die Zeilen zurück, bei denen die Verknüpfungsbedingung (meist Primary Key = Foreign Key) in <strong>beiden</strong> Tabellen erfüllt ist.</p>

<div style="background: #fff; padding: 1.5rem; border-radius: 8px; border: 1px solid #ddd; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0,0,0,0.05); text-align: center;">
    <p style="color: #2c3e50; font-weight: bold; font-size: 1.1rem; margin-bottom: 10px;">Das Venn-Diagramm des INNER JOIN</p>
    <div style="display: flex; justify-content: center; align-items: center; margin: 10px 0;">
        <div style="width: 100px; height: 100px; border-radius: 50%; background: rgba(52, 152, 219, 0.2); border: 2px solid #3498db; margin-right: -30px; z-index: 1;"></div>
        <div style="width: 100px; height: 100px; border-radius: 50%; background: rgba(46, 204, 113, 0.2); border: 2px solid #2ecc71; margin-left: -30px; z-index: 1;"></div>
        <!-- Schnittmenge simulieren -->
        <div style="position: absolute; width: 40px; height: 75px; border-radius: 50%; background: #9b59b6; z-index: 2;"></div>
    </div>
    <p style="color: #555; font-size: 0.9rem;">Nur die violette Schnittmenge wird ausgegeben.<br>Kunden ohne Bestellung und Bestellungen ohne Kunden (Gott bewahre!) fallen weg.</p>
</div>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 2rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.6;">-- Syntax: Welche Spalten wollen wir sehen?
SELECT kunden.vorname, kunden.nachname, bestellungen.rechnungsbetrag
-- Von welcher Haupttabelle gehen wir aus?
FROM kunden
-- Wie heißt die zweite Tabelle und wie sind sie verknüpft?
INNER JOIN bestellungen ON kunden.kunden_id = bestellungen.kunden_id;</code></pre></div>

<div style="background: #fef2f2; padding: 1.2rem; border-left: 4px solid #e74c3c; margin: 2rem 0; border-radius: 4px; color: #c0392b; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>🚨 Wichtig: Das kartesische Produkt (Gefahr!)</strong><br>
    Wenn man das <code>ON ... = ...</code> beim Verknüpfen vergisst, kombiniert SQL <em>jeden</em> Datensatz der ersten Tabelle mit <em>jedem</em> Datensatz der zweiten Tabelle. Bei 1.000 Kunden und 1.000 Bestellungen liefert die Datenbank plötzlich 1.000.000 unsinnige Zeilen zurück!
</div>', '', 'article', 'published', 17, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
