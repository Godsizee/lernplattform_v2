    }
]', 'quiz', 'published', 96, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lny65xsksagps83h3f1', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4550 - Kapitel 4', '', '[
    {
        "chapter": "Kapitel 4",
        "question": "Welches Konto wird beim Buchen einer Rechnung in der Logistik-Rechnungsprüfung aus dem Geschäftspartnersatz ermittelt?",
        "type": "radio",
        "options": {
            "A": "WE\\/RE-Verrechnungskonto",
            "B": "Bankkonto",
            "C": "Abstimmkonto",
            "D": "Preisdifferenzenkonto"
        },
        "correct": [
            "C"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welches der folgenden Szenarien hat Preisdifferenzenbuchungen zur Folge?",
        "type": "radio",
        "options": {
            "A": "Bewerteter Wareneingang; Material ist zum Standardpreis von 10 EUR bewertet; Bestellpreis beträgt 12 EUR",
            "B": "Bewerteter Wareneingang; Material ist zum gleitenden Durchschnittspreis von 10 EUR bewertet; Bestellung ist kostenlos",
            "C": "Wareneingang per Bestandsaufnahme in den frei verwendbaren Bestand; Material ist zum Standardpreis von 10 EUR bewertet; es ist kein externer Betrag eingegeben",
            "D": "Wareneingang zu Konsignationsbestellungen"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welche Buchungen sind für die Kontenfindung relevant?",
        "type": "checkbox",
        "options": {
            "A": "Umbuchung zwischen zwei Lagerorten innerhalb eines Werkes",
            "B": "Umbuchung zwischen zwei Werken",
            "C": "Umbuchung aus dem frei verwendbaren Bestand in den gesperrten Bestand",
            "D": "Umbuchung aus dem Konsignationsbestand in den eigenen Bestand"
        },
        "correct": [
            "B",
            "D"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welche Bewegungsarten sind für die Kontenfindung relevant?",
        "type": "checkbox",
        "options": {
            "A": "101 (Wareneingang zur Bestellung in das Lager)",
            "B": "103 (Wareneingang zur Bestellung in den WE-Sperrbestand)",
            "C": "105 (Freigabe des WE-Sperrbestands an das Lager)",
            "D": "109 (Wareneingang aus dem bewerteten Sperrbestand)"
        },
        "correct": [
            "A",
            "C"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Bei jeder Wareneingangsbuchung mit Bezug zu einer Bestellung wird ein Buchhaltungsbeleg erzeugt. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Die Bewegungsart, mit der ein Wareneingang erfasst wird, wirkt sich auf die Sachkonten der Wareneingangsbuchung aus. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welche der folgenden Elemente stellen Ebenen für die Bewertung und die Kontenfindung in der Materialwirtschaft (MM) dar?",
        "type": "checkbox",
        "options": {
            "A": "Bewertungskreis",
            "B": "Bewertungsart",
            "C": "Bewertungsabschnitt",
            "D": "Bewertungsgruppe"
        },
        "correct": [
            "A",
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Aus welcher Organisationsebene wird der Kontenplan ermittelt?",
        "type": "radio",
        "options": {
            "A": "Werk",
            "B": "Mandant",
            "C": "Buchungskreis",
            "D": "Bewertungskreis"
        },
        "correct": [
            "C"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Was ordnen Sie Werken zu, für die dieselben Einstellungen zur Kontenfindung gelten sollen?",
        "type": "radio",
        "options": {
            "A": "Dieselbe Bewertungsart",
            "B": "Dieselbe Bewertungsklasse",
            "C": "Dieselbe Bewertungsmodifikation",
            "D": "Dieselbe Bewertungsmodifikationskonstante"
        },
        "correct": [
            "D"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Die Ebene der Materialbewertung kann im Produktivsystem geändert werden. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Um die Produktionsplanung (Komponente PP) verwenden zu können, müssen Sie die Materialbewertung auf Buchungskreisebene einstellen. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Die Kontenfindung erfolgt immer werksabhängig. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Einem Buchungskreis kann nur ein operativer Kontenplan zugeordnet werden. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Was können Sie einer Materialart für die Kontenfindung zuordnen?",
        "type": "radio",
        "options": {
            "A": "Bewertungsklassen",
            "B": "Bewertungsmodifikationskonstante",
            "C": "Kontoklassenreferenz",
            "D": "Kontomodifikation"
        },
        "correct": [
            "C"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welche der folgenden Elemente sind direkt miteinander verknüpft?",
        "type": "checkbox",
        "options": {
            "A": "Bewertungsklasse – Kontoklassenreferenz",
            "B": "Bewertungsklasse – Materialart",
            "C": "Preissteuerung – Kontoklassenreferenz",
            "D": "Kontoklassenreferenz – Materialart"
        },
        "correct": [
            "A",
            "D"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Auf welchen Ebenen können Sie Bewertungsklassen zu Materialstammsätzen zuordnen?",
        "type": "checkbox",
        "options": {
            "A": "Bewertungskreis",
            "B": "Mandant",
            "C": "Dispositionsbereich",
            "D": "Bewertungsart"
        },
        "correct": [
            "A",
            "D"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Eine Bewertungsklasse kann mehreren Kontoklassenreferenzen zugeordnet werden. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Sie können einer Materialart mehrere Kontenklassenreferenzen zuordnen. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welche Anwendungsbereiche können Sie bei der Simulation der Kontenfindung auswählen?",
        "type": "checkbox",
        "options": {
            "A": "Zahlungsverkehr",
            "B": "Rechnungsprüfungsvorgänge",
            "C": "Einkaufsvorgänge",
            "D": "Bewegungen in der Bestandsführung"
        },
        "correct": [
            "B",
            "D"
        ],
        "link": "\\/module?id=s4550"
    },
    {
        "chapter": "Kapitel 4",
        "question": "Welcher Buchungsschlüssel wird für Bestandsbuchungen verwendet?",
        "type": "radio",
