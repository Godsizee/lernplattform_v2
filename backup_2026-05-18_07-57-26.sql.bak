INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l1hikhxll5onngtyr8v', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Abschreibungen auf Sachanlagen (AfA)', '
            <h3>1. Ursachen, Buchung und Wirkung</h3>
            <p>Das Anlagevermögen (z.B. Gebäude, Maschinen, Computer) soll dem Unternehmen <strong>langfristig</strong> dienen. Da diese Gegenstände aber nicht ewig halten, mindert sich ihr Wert. Diese Wertminderung wird in der Buchführung als <strong>Aufwand</strong> erfasst.</p>

            <div style="background: #e8f4f8; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem;">
                <strong>Ursachen für die Wertminderung:</strong>
                <ul>
                    <li>Nutzung (Gebrauch)</li>
                    <li>Natürlicher Verschleiß (Rost, Alterung)</li>
                    <li>Technischer Fortschritt (Veralterung, z.B. bei PCs)</li>
                </ul>
            </div>

            <h3>2. Berechnung der linearen Abschreibung</h3>
            <p>Bei der linearen Abschreibung werden die Anschaffungskosten gleichmäßig auf die Nutzungsdauer verteilt.</p>
            
            <div style="background: #fff; border: 2px solid #2c3e50; padding: 1.5rem; text-align: center; border-radius: 8px; margin: 1.5rem 0;">
                <code style="font-size: 1.2rem; color: #c0392b;">Abschreibungsbetrag = Anschaffungskosten / Nutzungsdauer (Jahre)</code><br><br>
                <code style="font-size: 1.2rem; color: #27ae60;">Abschreibungssatz (%) = 100 / Nutzungsdauer (Jahre)</code>
            </div>

            <h4>Beispiel: Die 120.000 € Maschine</h4>
            <p>Eine Maschine wird für <strong>120.000,00 €</strong> (netto) gekauft. Die Nutzungsdauer beträgt <strong>10 Jahre</strong>.</p>
            <ul>
                <li>Abschreibungsbetrag pro Jahr: 120.000 € / 10 Jahre = <strong>12.000,00 €</strong></li>
                <li>Abschreibungssatz: 100 / 10 = <strong>10 %</strong></li>
            </ul>

            <table style="width: 100%; border-collapse: collapse; margin-top: 1rem; box-shadow: var(--shadow-sm);">
                <tr style="background: var(--primary-color); color: #fff;">
                    <th style="padding: 10px;">Jahr</th>
                    <th style="padding: 10px; text-align: right;">Buchwert Jahresanfang</th>
                    <th style="padding: 10px; text-align: right;">Abschreibung (Aufwand)</th>
                    <th style="padding: 10px; text-align: right;">Buchwert Jahresende</th>
                </tr>
                <tr style="background: #f8f9fa;">
                    <td style="padding: 10px;">1</td>
                    <td style="padding: 10px; text-align: right;">120.000,00 €</td>
                    <td style="padding: 10px; text-align: right; color: #c0392b;">- 12.000,00 €</td>
                    <td style="padding: 10px; text-align: right;"><strong>108.000,00 €</strong></td>
                </tr>
                <tr>
                    <td style="padding: 10px;">2</td>
                    <td style="padding: 10px; text-align: right;">108.000,00 €</td>
                    <td style="padding: 10px; text-align: right; color: #c0392b;">- 12.000,00 €</td>
                    <td style="padding: 10px; text-align: right;"><strong>96.000,00 €</strong></td>
                </tr>
                <tr style="background: #f8f9fa;">
                    <td style="padding: 10px;">...</td>
                    <td style="padding: 10px; text-align: right;">...</td>
                    <td style="padding: 10px; text-align: right; color: #c0392b;">...</td>
                    <td style="padding: 10px; text-align: right;">...</td>
                </tr>
                <tr>
                    <td style="padding: 10px;">10</td>
                    <td style="padding: 10px; text-align: right;">12.000,00 €</td>
                    <td style="padding: 10px; text-align: right; color: #c0392b;">- 12.000,00 €</td>
                    <td style="padding: 10px; text-align: right;"><strong>0,00 €</strong> *</td>
                </tr>
            </table>
            <p style="font-size: 0.85rem; color: #666; margin-top: 5px;">* Wird der Gegenstand nach der Abschreibung weiter genutzt, bleibt ein <strong>Erinnerungswert von 1,00 €</strong> in den Büchern stehen.</p>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>3. Buchung in T-Konten</h3>
            <p>Die Abschreibung vermindert direkt den Wert des Anlagekontos (Haben) und stellt einen Aufwand dar (Soll).</p>

            <div style="display: flex; gap: 2rem; flex-wrap: wrap; justify-content: center; margin: 2rem 0;">
                <!-- AKTIVKONTO -->
                <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; background: #fff;">
                    <div style="background: #e0f2f1; padding: 5px; text-align: center; font-weight: bold; border-bottom: 1px solid #ccc;">S &nbsp;&nbsp; Techn. Anlagen und Maschinen &nbsp;&nbsp; H</div>
                    <div style="display: flex; justify-content: space-between; padding: 10px;">
                        <div>
                            <div>AB: 120.000</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="color: #c0392b;"><strong>Abschr.: 12.000</strong></div>
                            <div style="border-top: 1px solid #000; margin-top: 5px;">SBK: 108.000</div>
                        </div>
                    </div>
                </div>

                <!-- AUFWANDSKONTO -->
                <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; background: #fff;">
                    <div style="background: #ffebee; padding: 5px; text-align: center; font-weight: bold; border-bottom: 1px solid #ccc;">S &nbsp;&nbsp; Abschreibungen auf Sachanlagen &nbsp;&nbsp; H</div>
                    <div style="display: flex; justify-content: space-between; padding: 10px;">
                        <div>
                            <div style="color: #c0392b;"><strong>TA u. Masch.: 12.000</strong></div>
                        </div>
                        <div style="text-align: right;">
                            <div>GuV: 12.000</div>
                        </div>
                    </div>
                </div>
            </div>

            <div style="background: #f9f9f9; padding: 1.5rem; border-left: 4px solid #2c3e50;">
                <h4>Buchungssätze:</h4>
                <ol>
                    <li><strong>Erfassung der Abschreibung:</strong><br>
                    Abschreibungen auf Sachanlagen 12.000,00 an TA und Maschinen 12.000,00</li>
                    
                    <li><strong>Abschluss des Aufwandskontos:</strong><br>
                    GuV-Konto 12.000,00 an Abschreibungen auf Sachanlagen 12.000,00</li>
                    
                    <li><strong>Abschluss des Bestandskontos:</strong><br>
                    Schlussbilanzkonto 108.000,00 an TA und Maschinen 108.000,00</li>
                </ol>
            </div>

            <div style="margin-top: 2rem;">
                <h4>Typische Nutzungsdauern (AfA-Tabelle):</h4>
                <ul>
                    <li>Betriebsgebäude: 25 - 33 Jahre</li>
                    <li>PKW: 6 Jahre</li>
                    <li>Computer/Hardware: 3 Jahre</li>
                    <li>Büromöbel: 13 Jahre</li>
                </ul>
            </div>
        ', '', 'article', 'published', 30, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l1t5mgbs3hz6wpdfwfo', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4F10 - Kapitel 8', '', '[
    {
        "chapter": "Kapitel 8",
        "question": "Mit dem Financial Closing Cockpit können Sie Ihre Abschlussarbeiten auf verschiedenen Organisationsebenen organisieren. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
