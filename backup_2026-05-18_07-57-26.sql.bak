INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ln3atj14otm7grzdm69', 'sxh3e5ewi0qahenr6jg', 'u5ilhtdcn9ycti9tbmc', '1. Systemarchitektur & Transportwesen (CTS)', '<div style="margin-bottom: 3rem;">
    <span style="display: inline-block; padding: 0.35rem 1rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem; background: rgba(139, 92, 246, 0.15); border: 1px solid rgba(139, 92, 246, 0.3); color: #a78bfa;">Architektur</span>
    <h1 style="font-size: 2.5rem; font-weight: 800; color: #f8fafc; margin-bottom: 1.5rem; letter-spacing: -0.025em;">Das SAP 3-Schichten-Modell</h1>
    
    <div style="background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1.5rem; padding: 2.5rem; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3); margin-bottom: 2.5rem;">
        <ul style="list-style: none; padding: 0; margin: 0 0 2rem 0; color: #cbd5e1; line-height: 1.6; font-size: 0.95rem;">
            <li style="margin-bottom: 0.75rem;"><strong style="color: #f8fafc;">→ Präsentationsschicht:</strong> Benutzeroberfläche (SAP GUI, Browser). Nimmt Eingaben entgegen.</li>
            <li style="margin-bottom: 0.75rem;"><strong style="color: #f8fafc;">→ Applikationsschicht:</strong> Geschäftslogik. Dispatcher verteilt Anfragen an die Workprozesse. Hier laufen die ABAP-Programme.</li>
            <li><strong style="color: #f8fafc;">→ Datenbankschicht:</strong> Zentraler Speicher für Anwendungsdaten und Repository (Quellcode).</li>
        </ul>

        <div style="border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem;">
            <h3 style="color: #a78bfa; font-weight: 600; font-size: 1.05rem; margin-bottom: 1rem;">Systemlandschaft</h3>
            <ul style="list-style: none; padding: 0; margin: 0 0 1.5rem 0; color: #cbd5e1; line-height: 1.6; font-size: 0.95rem;">
                <li style="margin-bottom: 0.75rem;"><strong style="color: #f8fafc;">→ Entwicklungssystem (DEV):</strong> Hier wird programmiert und gecustomized.</li>
                <li style="margin-bottom: 0.75rem;"><strong style="color: #f8fafc;">→ Qualitätssicherungssystem (QAS):</strong> Hier wird getestet.</li>
                <li><strong style="color: #f8fafc;">→ Produktivsystem (PRD):</strong> Hier arbeiten die Endanwender mit echten Daten.</li>
            </ul>
        </div>
    </div>

    <h2 style="font-size: 2rem; font-weight: 800; color: #f8fafc; margin-bottom: 1.5rem; letter-spacing: -0.025em;">Transportwesen (CTS)</h2>
    <div style="background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1.5rem; padding: 2.5rem; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);">
        <div style="background: rgba(139, 92, 246, 0.05); border-left: 4px solid #8b5cf6; padding: 1rem 1.25rem; border-radius: 0 0.5rem 0.5rem 0; margin-bottom: 2rem; color: #cbd5e1; font-size: 0.95rem; line-height: 1.6;">
            <strong style="color: #f8fafc;">Zweck:</strong> Kontrollierter Transport von Objekten von DEV → QAS → PRD. Sicherstellung der Nachvollziehbarkeit & Konsistenz.
        </div>
        
        <p style="color: #f472b6; font-weight: 600; margin-bottom: 1rem; font-size: 0.95rem;">Transport Organizer (SE09 / SE10)</p>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; align-items: center; margin-top: 2rem;">
            <div style="flex: 1 1 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem; text-align: center;">
                <span style="display: block; color: #a78bfa; font-weight: 800; font-size: 1.1rem; margin-bottom: 0.5rem;">1.</span>
                <span style="font-size: 0.85rem; color: #cbd5e1;">Entwickeln</span>
            </div>
            <div style="color: #475569; font-weight: 800;">→</div>
            <div style="flex: 1 1 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem; text-align: center;">
                <span style="display: block; color: #a78bfa; font-weight: 800; font-size: 1.1rem; margin-bottom: 0.5rem;">2.</span>
                <span style="font-size: 0.85rem; color: #cbd5e1;">Freigeben</span>
            </div>
            <div style="color: #475569; font-weight: 800;">→</div>
            <div style="flex: 1 1 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem; text-align: center;">
                <span style="display: block; color: #a78bfa; font-weight: 800; font-size: 1.1rem; margin-bottom: 0.5rem;">3.</span>
                <span style="font-size: 0.85rem; color: #cbd5e1;">Import QAS</span>
            </div>
            <div style="color: #475569; font-weight: 800;">→</div>
            <div style="flex: 1 1 120px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem; text-align: center;">
                <span style="display: block; color: #a78bfa; font-weight: 800; font-size: 1.1rem; margin-bottom: 0.5rem;">4.</span>
                <span style="font-size: 0.85rem; color: #cbd5e1;">Import PRD</span>
            </div>
        </div>
    </div>
</div>', '', 'article', 'published', 47, '2026-04-28 19:54:05', '2026-04-28 19:54:05');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lnefunbbtpvo4se3b89', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4500 - Kapitel 1', '', '[
