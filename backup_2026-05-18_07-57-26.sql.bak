INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lplubwbrf2d420r0tkd', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Verhalten der Fixkosten', '
            <h3>1. Definition</h3>
            <p>Fixkosten fallen unabhängig von der Produktionsmenge an. Sie sind "eh da kosten" (Bereitschaftskosten).<br>
            <em>Beispiele: Miete, zeitabhängige Abschreibungen, Gehälter der Verwaltung, Kfz-Steuer.</em></p>

            <h3>2. Das Phänomen der Fixkostendegression</h3>
            <p>Das ist einer der wichtigsten Effekte in der BWL! Während die Fixkosten <strong>insgesamt</strong> immer gleich bleiben (z.B. 3.000 € Miete), werden sie <strong>pro Stück</strong> immer weniger, je mehr man produziert.</p>

            <div style="background: #e3f2fd; padding: 1.5rem; border-radius: 8px; margin: 1.5rem 0;">
                <h4 style="margin-top:0; color: #1565c0;">Beispiel: Stanze (Fixkosten: 3.000 €)</h4>
                <table style="width: 100%; text-align: right;">
                    <tr style="border-bottom: 1px solid #90caf9;">
                        <th style="text-align: left; padding: 5px;">Menge</th>
                        <th style="padding: 5px;">Fixkosten Gesamt</th>
                        <th style="padding: 5px; color: #1565c0;">Fixkosten je Stück</th>
                    </tr>
                    <tr>
                        <td style="text-align: left; padding: 5px;">1 Stk</td>
                        <td style="padding: 5px;">3.000 €</td>
                        <td style="padding: 5px; font-weight: bold;">3.000,00 €</td>
                    </tr>
                    <tr>
                        <td style="text-align: left; padding: 5px;">1.000 Stk</td>
                        <td style="padding: 5px;">3.000 €</td>
                        <td style="padding: 5px; font-weight: bold;">3,00 €</td>
                    </tr>
                    <tr>
                        <td style="text-align: left; padding: 5px;">6.000 Stk</td>
                        <td style="padding: 5px;">3.000 €</td>
                        <td style="padding: 5px; font-weight: bold;">0,50 €</td>
                    </tr>
                </table>
            </div>

            <p><strong>Fazit:</strong> Je höher die Auslastung, desto günstiger wird das Produkt, weil der "Fixkostenrucksack" pro Produkt kleiner wird.</p>
        ', '', 'article', 'published', 43, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
