INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lbl61lsn7i0knzea537', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Der Buchungskreislauf & Jahresabschluss', '
            <h3>1. Geschäftsgang mit Bestands- und Erfolgskonten</h3>
            <p>Hier fließen alle Fäden zusammen. Wir sehen, wie Bestandskonten (Bilanz) und Erfolgskonten (GuV) interagieren und wie der Gewinn das Eigenkapital erhöht.</p>

            <div style="display: flex; flex-direction: column; gap: 20px; background: #fff; padding: 1rem; border-radius: 8px; border: 1px solid #ddd;">
                
                <!-- Oben: Die Konten -->
                <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between;">
                    
                    <!-- AKTIVKONTEN -->
                    <div style="flex: 1; min-width: 200px; background: #e0f7fa; padding: 10px; border-radius: 4px;">
                        <strong style="color: #006064;">Aktivkonten</strong>
                        <ul style="font-size: 0.85em; padding-left: 15px; margin-top: 5px;">
                            <li>BGA: 380.000</li>
                            <li>Rohstoffe: 120.000</li>
                            <li>Forderungen: 11.500</li>
                            <li>Bank: 143.000</li>
                        </ul>
                    </div>

                    <!-- EIGENKAPITAL (ZENTRUM) -->
                    <div style="flex: 1; min-width: 200px; background: #fff9c4; padding: 10px; border-radius: 4px; border: 2px solid #fbc02d; text-align: center;">
                        <strong style="color: #f57f17;">Eigenkapital</strong>
                        <div style="font-size: 0.85em; margin-top: 5px; text-align: left;">
                            Soll: <br>
                            - Minderung<br>
                            <hr>
                            Haben:<br>
                            + AB: 380.000<br>
                            + Gewinn: 55.000 (aus GuV)
                        </div>
                    </div>

                    <!-- PASSIVKONTEN -->
                    <div style="flex: 1; min-width: 200px; background: #ffebee; padding: 10px; border-radius: 4px;">
                        <strong style="color: #b71c1c;">Passivkonten</strong>
                        <ul style="font-size: 0.85em; padding-left: 15px; margin-top: 5px;">
                            <li>Darlehen: 231.000</li>
                            <li>Verbindlichkeiten: 69.000</li>
                        </ul>
                    </div>
                </div>

                <!-- Mitte: Erfolgskonten fließen in GuV -->
                <div style="border-top: 2px dashed #ccc; padding-top: 15px; position: relative;">
                    <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #fff; padding: 0 10px; color: #777; font-size: 0.9em;">Erfolgskonten-Abschluss</div>
                    
                    <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                        <!-- AUFWENDUNGEN -->
                        <div style="flex: 1;">
                            <h5 style="color: #c0392b; margin: 0 0 5px 0;">Aufwandskonten (Soll GuV)</h5>
                            <div style="font-size: 0.85em; border-left: 3px solid #c0392b; padding-left: 10px;">
                                Aufw. f. Rohstoffe: 265.000<br>
                                Gehälter: 120.000<br>
                                Mietaufwand: 15.000<br>
                                Büromaterial: 800<br>
                                Instandhaltung: 1.500<br>
                                Betriebsteuern: 400<br>
                                <strong>Summe: 402.700</strong>
                            </div>
                        </div>

                        <!-- ERTRÄGE -->
                        <div style="flex: 1; text-align: right;">
                            <h5 style="color: #27ae60; margin: 0 0 5px 0;">Ertragskonten (Haben GuV)</h5>
                            <div style="font-size: 0.85em; border-right: 3px solid #27ae60; padding-right: 10px;">
                                Umsatzerlöse: 454.000<br>
                                Provisionserträge: 23.300<br>
                                Zinserträge: 2.700<br>
                                <br><br>
                                <strong>Summe: 480.000</strong>
                            </div>
                        </div>
                    </div>

                    <!-- Das GuV Konto -->
                    <div style="margin-top: 20px; background: #f5f5f5; padding: 10px; border-radius: 4px;">
                        <table style="width: 100%; font-size: 0.9em;">
                            <tr>
                                <th colspan="2" style="border-bottom: 1px solid #999;">GuV-Konto</th>
                            </tr>
                            <tr>
                                <td style="width: 50%; border-right: 1px solid #999; vertical-align: top;">
                                    Soll (Aufwendungen): 402.700<br>
                                    <span style="color: #27ae60; font-weight: bold;">Gewinn (Saldo): 77.300</span>
                                </td>
                                <td style="width: 50%; vertical-align: top;">
                                    Haben (Erträge): 480.000
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Unten: Schlussbilanz -->
                <div style="background: #e8f5e9; padding: 10px; border-radius: 4px; border: 1px solid #a5d6a7; text-align: center;">
                    <strong style="color: #1b5e20;">Schlussbilanz (SBK)</strong>
                    <p style="font-size: 0.9em; margin: 5px 0;">Das Eigenkapital ist nun auf <strong>457.300</strong> gewachsen (380.000 AB + 77.300 Gewinn).</p>
                </div>
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>2. Reihenfolge der buchungstechnischen Arbeiten</h3>
            <p>Der Jahresabschluss folgt einem strengen logischen Ablauf:</p>

            <ol style="background: #fff; padding: 20px 40px; border-radius: 8px; border-left: 5px solid #2c3e50;">
                <li style="margin-bottom: 10px;"><strong>Eröffnungsbilanz aufstellen:</strong> Werte aus der Schlussbilanz des Vorjahres übernehmen.</li>
                <li style="margin-bottom: 10px;"><strong>Eröffnung der Bestandskonten:</strong>
                    <ul>
                        <li>Aktivkonten an EBK</li>
                        <li>EBK an Passivkonten</li>
                    </ul>
                </li>
                <li style="margin-bottom: 10px;"><strong>Laufende Geschäftsvorfälle buchen:</strong> Das ganze Jahr über im Grund- und Hauptbuch.</li>
                <li style="margin-bottom: 10px;"><strong>Abschluss der Erfolgskonten:</strong>
                    <ul>
                        <li>GuV an Aufwandskonten</li>
                        <li>Ertragskonten an GuV</li>
                    </ul>
                </li>
                <li style="margin-bottom: 10px;"><strong>Abschluss des GuV-Kontos:</strong> Ermittlung von Gewinn oder Verlust und Übertrag auf das Eigenkapital.
                    <ul>
                        <li>Gewinn: GuV an Eigenkapital</li>
                        <li>Verlust: Eigenkapital an GuV</li>
                    </ul>
                </li>
                <li style="margin-bottom: 10px;"><strong>Abschluss der Bestandskonten:</strong> Salden bilden und auf das Schlussbilanzkonto (SBK) übertragen.</li>
                <li><strong>Schlussbilanz aufstellen:</strong> Das SBK ist die Schlussbilanz.</li>
            </ol>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>3. Die Kontenkreise</h3>
            <p>In der doppelten Buchführung gibt es zwei Kreisläufe, die nur über das <strong>Eigenkapital</strong> verbunden sind.</p>

            <div style="display: flex; gap: 10px; align-items: center; justify-content: center; margin-top: 2rem; flex-wrap: wrap;">
                
                <!-- Bestandskontenkreis -->
                <div style="background: #e3f2fd; padding: 20px; border-radius: 10px; border: 2px solid #2196f3; width: 45%; min-width: 280px;">
                    <h4 style="color: #0d47a1; text-align: center; margin-top: 0;">Bestandskontenkreis</h4>
                    <div style="display: flex; justify-content: space-between; font-size: 0.9em;">
                        <div style="background: #fff; padding: 5px; border-radius: 4px;">Aktivkonten</div>
                        <div style="background: #fff; padding: 5px; border-radius: 4px;">Passivkonten</div>
                    </div>
                    <div style="text-align: center; margin: 10px 0;">&darr;</div>
                    <div style="background: #fff; padding: 10px; text-align: center; font-weight: bold; border: 1px solid #ccc;">Schlussbilanzkonto</div>
                </div>

                <div style="font-size: 2rem; color: #555;">&harr;</div>

                <!-- Erfolgskontenkreis -->
                <div style="background: #fce4ec; padding: 20px; border-radius: 10px; border: 2px solid #e91e63; width: 45%; min-width: 280px;">
                    <h4 style="color: #880e4f; text-align: center; margin-top: 0;">Erfolgskontenkreis</h4>
                    <div style="display: flex; justify-content: space-between; font-size: 0.9em;">
                        <div style="background: #fff; padding: 5px; border-radius: 4px;">Aufwendungen</div>
                        <div style="background: #fff; padding: 5px; border-radius: 4px;">Erträge</div>
                    </div>
                    <div style="text-align: center; margin: 10px 0;">&darr;</div>
                    <div style="background: #fff; padding: 10px; text-align: center; font-weight: bold; border: 1px solid #ccc;">GuV-Konto</div>
                </div>
            </div>

            <div style="text-align: center; margin-top: 10px; font-weight: bold; padding: 10px; background: #fff9c4; border: 2px solid #fbc02d; border-radius: 8px;">
                Verbindung: Saldo GuV (Gewinn/Verlust) &rarr; Eigenkapital
            </div>
        ', '', 'article', 'published', 29, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lbpt33m16jilb6nq7j1', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'Physisches Datenmodell: Datentypen in SQL', '<h3>1. Von der Theorie zur echten Tabelle</h3>
<p>Nachdem das Modell in die 3. Normalform gebracht wurde, beginnt die physische Implementierung im Datenbankmanagementsystem (DBMS). Bevor wir jedoch eine Tabelle erstellen können, müssen wir dem System mitteilen, <strong>welche Art von Daten</strong> in den jeweiligen Spalten gespeichert werden darf. Das sorgt für extreme Typsicherheit und spart Speicherplatz.</p>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Die wichtigsten SQL-Datentypen</h3>
<p>Jedes DBMS (MySQL, PostgreSQL, Oracle) hat leichte Variationen, aber die folgenden Standard-Typen funktionieren fast überall:</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    
    <!-- Zahlen -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #2980b9;">🔢 Zahlen (Numerisch)</h4>
        <ul style="color: #555; font-size: 0.9rem; padding-left: 1.2rem; margin-bottom: 0;">
            <li><code style="color: #2980b9;">INT</code> oder <code style="color: #2980b9;">INTEGER</code>: Ganze Zahlen (z. B. für IDs oder Mengen).</li>
            <li><code style="color: #2980b9;">DECIMAL(p, s)</code>: Exakte Kommazahlen. Das <em>p</em> steht für die Gesamtzahl der Ziffern, <em>s</em> für die Nachkommastellen (z. B. <code>DECIMAL(8,2)</code> für Geldbeträge bis 999.999,99).</li>
        </ul>
    </div>

    <!-- Zeichenketten -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">🔤 Zeichenketten (Strings)</h4>
        <ul style="color: #555; font-size: 0.9rem; padding-left: 1.2rem; margin-bottom: 0;">
            <li><code style="color: #d35400;">VARCHAR(n)</code>: Text mit variabler Länge bis maximal <em>n</em> Zeichen (z. B. für Namen, E-Mails). Spart Speicherplatz!</li>
            <li><code style="color: #d35400;">CHAR(n)</code>: Text mit exakt <em>n</em> Zeichen Länge (z. B. für feste Länderkürzel wie ''DE'').</li>
            <li><code style="color: #d35400;">TEXT</code>: Für sehr lange Texte (Beschreibungen, Blogbeiträge).</li>
        </ul>
    </div>

    <!-- Datum & Zeit -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f0fdf4; border-left: 4px solid #2ecc71; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #27ae60;">📅 Datum und Uhrzeit</h4>
        <ul style="color: #555; font-size: 0.9rem; padding-left: 1.2rem; margin-bottom: 0;">
            <li><code style="color: #27ae60;">DATE</code>: Nur das Datum (YYYY-MM-DD).</li>
            <li><code style="color: #27ae60;">TIME</code>: Nur die Uhrzeit (HH:MI:SS).</li>
            <li><code style="color: #27ae60;">TIMESTAMP</code> / <code style="color: #27ae60;">DATETIME</code>: Datum inklusive exakter Uhrzeit (ideal für Erstellungsdaten oder Logs).</li>
        </ul>
    </div>

</div>', '', 'article', 'published', 11, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lcovqdraffdjdngnvis', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Betriebsabrechnungsbogen', '
            <h3>Ziel</h3>
            <p>Ermittlung der Gemeinkostenzuschlagssätze für Material, Fertigung, Verwaltung und Vertrieb.</p>
            <p><code>Zuschlagssatz = (Gemeinkosten * 100) / Einzelkosten</code></p>
        ', '', 'article', 'published', 38, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ld07i8xwb3iqxvx4ly0', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Netzwerk: HTTP POST Requests in Java', '<h3>1. API-Anfragen mit Java</h3>
<p>Um aus einer Java-Anwendung heraus eine Schnittstelle (wie die OpenAI API) anzusprechen, müssen wir als <strong>Client</strong> fungieren. Seit Java 11 gibt es dafür den hochmodernen und einfachen <code>java.net.http.HttpClient</code>.</p>

<h3>2. Aufbau eines POST-Requests</h3>
<p>Wenn wir Daten an eine KI senden wollen, benötigen wir einen POST-Request. Dieser besteht aus 3 wichtigen Bestandteilen:</p>
<ul style="background: #fdf2f8; padding: 1.5rem 2.5rem; border-radius: 8px; border: 1px solid #fce4ec; color: #880e4f; line-height: 1.7;">
    <li><strong>Der URL:</strong> Wohin geht die Anfrage? (z.B. <code>https://api.openai.com/v1/chat/completions</code>)</li>
    <li><strong>Dem Header:</strong> Metadaten! Hier teilen wir mit, dass wir JSON senden (<code>Content-Type</code>) und legitimieren uns durch unseren geheimen API-Schlüssel (<code>Authorization: Bearer SECRET_TOKEN</code>).</li>
    <li><strong>Dem Body:</strong> Der eigentliche Inhalt. Bei OpenAI ist dies ein JSON-String, der das Modell und unseren Text enthält.</li>
</ul>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Die Praxis: Senden an OpenAI</h3>
<p>Hier ist die saubere Implementierung einer Methode, die einen JSON-Payload (den vorbereiteten String) sicher an die OpenAI-Schnittstelle übermittelt.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;

public class ApiService {

    public void sendOpenAIRequest(String jsonPayload, String apiKey) {
        try {
            // 1. Den Client instanziieren (das Werkzeug, das den Request ausführt)
            HttpClient client = HttpClient.newHttpClient();

            // 2. Den Request bauen (POST definieren, Header setzen, Body anhängen)
            HttpRequest request = HttpRequest.newBuilder()
                    .uri(URI.create("https://api.openai.com/v1/chat/completions"))
                    .header("Content-Type", "application/json")
                    .header("Authorization", "Bearer " + apiKey)
                    .POST(HttpRequest.BodyPublishers.ofString(jsonPayload))
                    .build();

            // 3. Den Request synchron absenden und auf die Antwort warten
            HttpResponse&lt;String&gt; response = client.send(request, HttpResponse.BodyHandlers.ofString());

            // 4. Den Statuscode prüfen
            if (response.statusCode() == 200) {
                System.out.println("Erfolgreich geantwortet:");
                System.out.println(response.body()); // Hier steckt das JSON von der KI drin!
            } else {
                System.err.println("API-Fehler! Status: " + response.statusCode());
                System.err.println(response.body());
            }

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}</code></pre></div>', '', 'article', 'published', 70, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lda3u3ju6uhqf29mvai', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Bestandsveränderungen (BV)', '
            <h3>1. Das Problem: Produktion ≠ Absatz</h3>
            <p>In einem Industriebetrieb stimmen die hergestellte Menge und die verkaufte Menge selten genau überein.</p>
            <ul>
                <li><strong>Herstellungsmenge > Absatzmenge:</strong> Das Lager füllt sich. Wir haben einen <strong>Mehrbestand</strong>.</li>
                <li><strong>Herstellungsmenge < Absatzmenge:</strong> Das Lager leert sich (Verkauf aus alten Beständen). Wir haben einen <strong>Minderbestand</strong>.</li>
            </ul>

            <div style="background: #fff3cd; padding: 1rem; border-left: 4px solid #ffc107; margin: 1.5rem 0;">
                <strong>Merke:</strong><br>
                Bestandsveränderungen an fertigen und unfertigen Erzeugnissen müssen am Jahresende erfasst werden, damit der Erfolg (Gewinn/Verlust) periodengerecht ermittelt wird.
            </div>

            <h3>2. Fallbeispiel: Die Fahrradfabrik</h3>
            <p>Eine Fahrradfabrik stellt im 1. Geschäftsjahr 1.000 Fahrräder her. Die Herstellungskosten betragen <strong>400,00 € pro Stück</strong>. Alle Fahrräder werden für 600,00 € verkauft.</p>
            <p><em>Ergebnis: Gewinn = Erlöse (600.000) - Aufwand (400.000) = 200.000 €. Alles einfach.</em></p>

            <h4>Szenario: Mehrbestand (Lageraufbau)</h4>
            <p>Im 2. Jahr produziert die Fabrik <strong>2.000 Fahrräder</strong>, verkauft aber nur <strong>1.500 Stück</strong>.</p>
            <ul>
                <li>Produktion: 2.000 Stück</li>
                <li>Verkauf: 1.500 Stück</li>
                <li><strong>Lagerbestand (Neu): 500 Stück</strong></li>
            </ul>
            <p>Der Wert dieser 500 Fahrräder (500 Stk. * 400 € = <strong>200.000 €</strong>) darf nicht als Verlust (Aufwand) erscheinen, da die Räder ja noch im Lager liegen und einen Wert darstellen.</p>

            <h3>3. Buchung der Bestandsveränderung</h3>
            <p>Die Bestandsmehrung wird wie ein <strong>Ertrag</strong> behandelt, da das Unternehmen Werte geschaffen hat ("Leistung"), die noch nicht verkauft wurden.</p>

            <div style="display: flex; gap: 2rem; margin: 2rem 0; flex-wrap: wrap;">
                <!-- KONTO Fertige Erzeugnisse -->
                <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; background: #fff;">
                    <div style="background: #e0f2f1; padding: 5px; text-align: center; font-weight: bold; border-bottom: 1px solid #ccc;">S &nbsp;&nbsp; Fertige Erzeugnisse (Bestand) &nbsp;&nbsp; H</div>
                    <div style="display: flex; justify-content: space-between; padding: 10px;">
                        <div>AB: 0</div>
                        <div style="text-align: right;">
                            <div style="border-top: 1px solid #000; margin-top: 5px; color: #c0392b;"><strong>SBK: 200.000</strong></div>
                        </div>
                    </div>
                </div>

                 <!-- KONTO BV -->
                 <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; background: #fff;">
                    <div style="background: #e8f5e9; padding: 5px; text-align: center; font-weight: bold; border-bottom: 1px solid #ccc;">S &nbsp;&nbsp; Bestandsveränderungen (Erfolg) &nbsp;&nbsp; H</div>
                    <div style="display: flex; justify-content: space-between; padding: 10px;">
                        <div>GuV: ...</div>
                        <div style="text-align: right;">
                            <div style="color: #27ae60;"><strong>Bestandsmehrung: 200.000</strong></div>
                        </div>
                    </div>
                </div>
            </div>

            <div style="background: #f9f9f9; padding: 1.5rem; border-left: 4px solid #2c3e50;">
                <h4>Buchungssätze zum Jahresabschluss:</h4>
                <ol>
                    <li><strong>Abschluss des Bestandskontos:</strong><br>
                    Schlussbilanzkonto an Fertige Erzeugnisse 200.000,00</li>
                    
                    <li><strong>Buchung der Bestandsveränderung (Mehrung):</strong><br>
                    Fertige Erzeugnisse an Bestandsveränderungen 200.000,00<br>
                    <em>(Das Bestandskonto wird angepasst, die BV ist ein Ertrag)</em></li>
                    
                    <li><strong>Abschluss des Erfolgskontos BV:</strong><br>
                    Bestandsveränderungen an GuV-Konto 200.000,00</li>
                </ol>
            </div>

            <h4>Zusammenfassung der Regeln:</h4>
            <ul>
                <li><strong>Schlussbestand (SB) > Anfangsbestand (AB):</strong><br>
                = Bestandsmehrung -> Buchung: <code>Fertige Erzeugnisse an BV</code> (Ertrag)</li>
                <li><strong>Schlussbestand (SB) < Anfangsbestand (AB):</strong><br>
                = Bestandsminderung -> Buchung: <code>BV an Fertige Erzeugnisse</code> (Aufwand)</li>
            </ul>
        ', '', 'article', 'published', 33, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
