]', 'quiz', 'published', 108, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lj9lsug7imew42v4pu4', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Design Patterns: Die Factory Method', '<h3>1. Was ist das Factory Pattern?</h3>
<p>Das Factory Pattern (Fabrikmethode) ist ein <strong>Erzeugungsmuster</strong> in der Softwareentwicklung. Es lagert die Instanziierung (Erstellung) von Objekten in eine spezielle Fabrik-Klasse aus, anstatt Objekte überall im Code verstreut mit <code>new</code> zu erzeugen.</p>

<div style="background: #f0fdf4; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #2ecc71; margin: 1.5rem 0; box-shadow: 0 4px 10px rgba(46, 204, 113, 0.1);">
    <h4 style="margin-top:0; color: #27ae60;">✨ Der große Vorteil</h4>
    <p style="margin: 0; color: #1e824c;">Durch die Factory wird der Code extrem wartbar. Wenn sich der Erstellungsprozess eines Objekts ändert oder neue Produkttypen (z.B. ein <em>Regal</em>) hinzukommen, muss der Code nur an <strong>genau einer Stelle</strong> (in der Factory) angepasst werden. Das System folgt dem <strong>Open/Closed Principle</strong> (offen für Erweiterungen, geschlossen für Veränderungen).</p>
</div>

<h3>2. Praxisbeispiel: Der Möbelhersteller</h3>
<p>Eine Firma produziert Stühle, Tische und Schränke. Wir definieren zuerst eine gemeinsame Schnittstelle (Interface) und nutzen dann ein Enum, um der Factory mitzuteilen, welches Möbelstück wir benötigen.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">// 1. Die gemeinsame Schnittstelle
public interface Furniture {
    void build();
}

// 2. Konkrete Produkte
public class Chair implements Furniture {
    public void build() { System.out.println("Baue Stuhl..."); }
}
public class Table implements Furniture {
    public void build() { System.out.println("Baue Tisch..."); }
}
public class Cabinet implements Furniture {
    public void build() { System.out.println("Baue Schrank..."); }
}

// 3. Typ-Sicherheit durch ein Enum
public enum FurnitureType {
    CHAIR, TABLE, CABINET, SHELF
}

// 4. Die Factory (Die "Fabrik")
public class FurnitureFactory {
    public Furniture getFurniture(FurnitureType type) {
        return switch (type) {
            case CHAIR -> new Chair();
            case TABLE -> new Table();
            case CABINET -> new Cabinet();
            default -> throw new IllegalArgumentException("Unbekanntes Möbelstück!");
        };
    }
}

// --- Verwendung ---
public class Main {
    public static void main(String[] args) {
        FurnitureFactory factory = new FurnitureFactory();
        
        // Wir bestellen Möbel, ohne das ''new'' Keyword für die Möbel selbst zu nutzen!
        Furniture myChair = factory.getFurniture(FurnitureType.CHAIR);
        myChair.build(); // Ausgabe: Baue Stuhl...
    }
}</code></pre></div>', '', 'article', 'published', 67, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ljqhypeipckhfj395r9', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Entwurfsmuster (Design Patterns)', '<h3>1. Was sind Entwurfsmuster?</h3>
<p>Design Patterns (Entwurfsmuster) sind wiederverwendbare, formal korrekte Vorlagen zur Lösung von wiederkehrenden Designproblemen in der Softwareentwicklung. Ihren weltweiten Durchbruch feierten sie 1994 durch das berühmte Buch der <strong>"Gang of Four" (GoF)</strong>.</p>

<div style="background: #fff3cd; padding: 1.2rem; border-left: 4px solid #ffc107; margin: 1.5rem 0; border-radius: 4px; color: #856404; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>📚 Die 3 großen Kategorien:</strong> Man unterteilt Entwurfsmuster typischerweise in <strong>Erzeugungsmuster</strong> (Regeln zur sicheren Objekterstellung, z.B. Singleton), <strong>Strukturmuster</strong> (Klassenaufbau, z.B. Decorator) und <strong>Verhaltensmuster</strong> (Zusammenspiel von Objekten, z.B. Observer).
</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Praxis-Fokus: Das Decorator Pattern (Strukturmuster)</h3>
<p>Oft reicht klassische Vererbung nicht aus, da sie bereits zur Kompilierzeit starr festgelegt wird. Das <strong>Decorator Pattern</strong> erlaubt es stattdessen, Objekte <em>zur Laufzeit</em> dynamisch mit völlig neuen Funktionalitäten zu erweitern ("dekorieren"), ohne die zugrundeliegende Basis-Klasse verändern zu müssen!</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">// 1. Die gemeinsame Schnittstelle
interface Coffee {
    double getCost();
    String getDescription();
}

// 2. Das nackte Basis-Objekt
class SimpleCoffee implements Coffee {
    public double getCost() { return 2.0; }
    public String getDescription() { return "Einfacher Kaffee"; }
}

// 3. Der abstrakte Decorator (enthält die Delegation)
abstract class CoffeeDecorator implements Coffee {
    protected final Coffee decoratedCoffee;
    
    public CoffeeDecorator(Coffee coffee) {
        this.decoratedCoffee = coffee;
    }
    
    public double getCost() { return decoratedCoffee.getCost(); }
    public String getDescription() { return decoratedCoffee.getDescription(); }
}

// 4. Ein konkreter Decorator (fügt dynamisch Milch hinzu!)
class MilkDecorator extends CoffeeDecorator {
    public MilkDecorator(Coffee coffee) {
        super(coffee); // Gibt den Kaffee an den abstrakten Decorator weiter
    }
    
    @Override
    public double getCost() { 
        return super.getCost() + 0.5; // Kostet 50 Cent mehr
    }
    
    @Override
    public String getDescription() { 
        return super.getDescription() + ", Milch"; 
    }
}

// --- Verwendung zur Laufzeit ---
public class Main {
    public static void main(String[] args) {
        // Wir machen uns einen einfachen Kaffee
        Coffee myCoffee = new SimpleCoffee();
        
        // Wir dekorieren ihn dynamisch mit Milch (ohne die SimpleCoffee-Klasse anzufassen!)
        myCoffee = new MilkDecorator(myCoffee); 
        
        System.out.println(myCoffee.getDescription() + " kostet " + myCoffee.getCost() + " Euro");
    }
}</code></pre></div>', '', 'article', 'published', 57, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ljyn9pyxsjvbzg9tmql', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'Über den Tellerrand: NoSQL Datenbanken', '<h3>1. Wenn das Relationale Modell an seine Grenzen stößt</h3>
<p>Relationale Datenbanken (SQL) sind Weltklasse, solange die Daten eine extrem feste Struktur (Schema) haben und auf einem einzigen, riesigen Server liegen. Doch im Zeitalter von Big Data (z.B. Facebook, Amazon, IoT-Sensoren) entstand ein Problem:</p>
<ul style="color: #444; line-height: 1.7; padding-left: 1.5rem;">
    <li>Daten lassen sich oft nicht mehr in starre Tabellen pressen (unstrukturierte Daten).</li>
    <li>Ein einzelner Server lässt sich irgendwann nicht mehr aufrüsten (Scale-Up). Die Datenbank muss auf Hunderte kleine Server verteilt werden (Scale-Out). Hier versagt das ACID-Prinzip klassischer SQL-Datenbanken oft.</li>
</ul>
<p>Die Lösung? <strong>NoSQL (Not Only SQL)</strong>.</p>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Die vier großen Familien der NoSQL-Datenbanken</h3>

<table style="width: 100%; border-collapse: collapse; margin-top: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 0.95rem; border-radius: 8px; overflow: hidden;">
    <thead>
        <tr style="background: linear-gradient(135deg, #8e44ad, #9b59b6); color: #fff;">
            <th style="padding: 15px; text-align: left; width: 25%;">Datenbank-Typ</th>
            <th style="padding: 15px; text-align: left; width: 75%;">Architektur & Bekannte Vertreter</th>
        </tr>
    </thead>
    <tbody>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #333;">📄 Dokumentenorientiert</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #555;">Speichert Daten oft in verschachtelten JSON-Dokumenten. Jedes Dokument darf eine völlig andere Struktur haben. Keine fixen Tabellenschemata nötig!<br><em>Bekanntester Vertreter: <strong>MongoDB</strong></em></td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #333;">🔑 Key-Value-Stores</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #555;">Das simpelste Konzept überhaupt: Ein eindeutiger Schlüssel verweist auf einen Wert (z. B. ein Bild oder ein Objekt). Extrem schnell, oft komplett im Arbeitsspeicher (In-Memory). Ideal als Caching-Layer.<br><em>Bekanntester Vertreter: <strong>Redis</strong></em></td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #333;">🕸️ Graphendatenbanken</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #555;">Speichert Daten in Form von Knoten (Personen) und Kanten (Beziehungen). Perfekt für Netzwerke wie Facebook ("Wer ist über wie viele Ecken mit wem befreundet?"). Komplexe JOINs entfallen.<br><em>Bekanntester Vertreter: <strong>Neo4j</strong></em></td>
        </tr>
        <tr>
            <td style="padding: 15px; font-weight: bold; color: #333;">🏛️ Spaltenorientiert</td>
            <td style="padding: 15px; color: #555;">Die Daten werden nicht zeilenweise, sondern spaltenweise auf der Festplatte gespeichert. Das macht Aggregationen (z. B. "Summe aller Umsätze") pfeilschnell, da man nicht jede ganze Zeile in den RAM laden muss.<br><em>Bekanntester Vertreter: <strong>Cassandra</strong></em></td>
        </tr>
    </tbody>
</table>', '', 'article', 'published', 22, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lk878en415cfn68jth9', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4F10 - Kapitel 5', '', '[
    {
        "chapter": "Kapitel 5",
        "question": "Der Bereich für die allgemeinen Daten des Geschäftspartnerstammsatzes muss für jeden Buchungskreis, der Geschäfte mit diesem Debitor tätigt, separat angelegt werden. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 5",
        "question": "Wodurch wird die Buchung für einen Debitor mit dem Hauptbuch verknüpft?",
        "type": "radio",
        "options": {
            "A": "Abstimmkonto",
            "B": "Belegart",
            "C": "Buchungsschlüssel",
            "D": "Kontengruppe"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 5",
        "question": "Wenn eine Teilzahlung für einen Zahlungseingang mit der Methode \\"Teilzahlung\\" verarbeitet wird, wird die Rechnung beglichen und ein neuer offener Posten in Höhe der Zahlungsdifferenz angelegt. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 5",
        "question": "Verschiedene Ausgangsrechnungen, die nicht zu einem Kundenauftrag gehören, können nur über herkömmliche SAP-GUI-Transaktionen in der Komponente für die Debitorenbuchhaltung erfasst werden. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 5",
        "question": "Wie kann eingesehen werden, ob ein Debitor gemahnt wurde? Wählen Sie die richtige Antwort.",
