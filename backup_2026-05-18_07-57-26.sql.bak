INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lgszk4wtsuhhmrx9k0d', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Kompakte Datenklassen: Records', '<h3>1. Das Problem: Boilerplate-Code</h3>
<p>Bei der Erstellung von Klassen, die primär als reine Datencontainer dienen (sogenannte <em>Data Transfer Objects</em> oder <em>POJOs</em>), fällt in Java traditionell massiv immergleicher Standardcode an: Attribute, Konstruktoren, Getter, Setter, <code>equals()</code>, <code>hashCode()</code> und <code>toString()</code>. Diesen unnötigen Code-Ballast nennt man <strong>Boilerplate</strong>.</p>

<div style="background: #e8f4f8; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #3498db; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <h4 style="margin-top:0; color: #2980b9;">🚀 Die Lösung ab Java 14: Records</h4>
    <p style="margin: 0; color: #2c3e50;">Um unveränderliche Datenklassen extrem schnell, sicher und kompakt zu implementieren, wurden <strong>Records</strong> eingeführt.</p>
</div>

<h3>2. Deklaration & Verwendung</h3>
<p>Records werden mit dem Schlüsselwort <code>record</code> deklariert. Der Compiler generiert automatisch den Konstruktor und die Getter (die hier genauso heißen wie das Attribut, also z.B. <code>name()</code> anstatt <code>getName()</code>).</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">// Deklaration (das ist tatsächlich die komplette Klasse!)
public record Person(String name, int age) {}

// Verwendung im Code:
Person person = new Person("Max Mustermann", 29);

String name = person.name(); // Getter wird automatisch generiert
int age = person.age();</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Zusätzliche Methoden & Validierung</h3>
<p>Man kann Records erweitern. Sehr häufig wird eine Kompakt-Syntax des Konstruktors genutzt, um Parameter direkt bei der Erstellung zu validieren.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">public record Person(String name, int age) {
    
    // Kompakter Konstruktor für Validierungen
    public Person {
        if (age < 0) {
            throw new IllegalArgumentException("Alter darf nicht negativ sein!");
        }
    }

    // Zusätzliche eigene Methode
    public String greeting() {
        return "Hallo, ich bin " + name;
    }
}</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>4. Einschränkungen (Wichtig!)</h3>
<p>Da Records ein klares Ziel verfolgen (unveränderliche Datenträger zu sein), gelten strenge Regeln:</p>
<ul style="background: #fdf2f8; padding: 1.5rem 2.5rem; border-radius: 8px; border: 1px solid #fce4ec; color: #880e4f; line-height: 1.7;">
    <li>Records sind grundsätzlich <strong>final</strong> (man kann nicht von ihnen erben).</li>
    <li>Sie können jedoch <strong>Interfaces</strong> implementieren.</li>
    <li>Alle Attribute sind automatisch <strong>private final</strong> (sie sind <strong>immutable</strong> / zur Laufzeit unveränderlich!).</li>
    <li>Es gibt <strong>keine Setter</strong> und sie dürfen auch nicht manuell implementiert werden.</li>
    <li>Es dürfen keine zusätzlichen Instanzvariablen definiert werden (alles muss in den runden Klammern oben stehen).</li>
</ul>', '', 'article', 'published', 66, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lhocehsjg5nkbnkn12e', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4220 - Kapitel 8', '', '[
    {
        "chapter": 8,
        "question": "1. Welche Einstellungen finden Sie in einer Feinplanungsstrategie?",
        "type": "checkbox",
        "options": {
            "A": "ob die Terminierung in Nichtarbeitszeiten erfolgt",
            "B": "ob Planaufträge oder Bestellanforderungen angelegt werden",
            "C": "Planungsrichtung, ausgehend vom Wunschtermin",
            "D": "das Losgrößenverfahren"
        },
        "correct": [
            "A",
            "C"
        ],
        "link": "s4220.php#k8-l1"
    },
    {
        "chapter": 8,
        "question": "2. Welches Werkzeug ist das zentrale Werkzeug für die interaktive Kapazitätsplanung in der erweiterten Planung von SAP S\\/4HANA?",
        "type": "radio",
        "options": {
            "A": "Produktsicht",
            "B": "Produktübersicht",
            "C": "Feinplanungsplantafel",
            "D": "Planungstableau"
        },
        "correct": [
            "C"
        ],
        "link": "s4220.php#k8-l2"
    },
    {
