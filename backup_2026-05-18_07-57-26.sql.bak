INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ltt9l9k7g9fn4ttj86v', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'JSON Parsing in Java', '<h3>1. Die Problemstellung beim Datenaustausch</h3>
<p>Wenn wir Daten über das Netzwerk austauschen (z.B. durch eine REST-API Anfrage), erhalten wir diese oft nur als simplen, endlosen JSON-String. Um in Java objektorientiert damit arbeiten zu können, müssen wir diesen Textbaum in konkrete Java-Objekte übersetzen. Diesen fundamentalen Prozess nennt man <strong>Parsen</strong>.</p>

<h3>2. JSON Parsen mit dem SimpleJSON Framework</h3>
<p>Das Framework <code>SimpleJSON</code> ist ein herrliches, leichtgewichtiges Tool, um JSON-Strings in Javas <code>JSONObject</code> und <code>JSONArray</code> zu wandeln. Aus diesen Strukturen können wir dann die eigentlichen Werte extrahieren und unsere eigenen Model-Klassen instanziieren.</p>

<div style="background: #fff3cd; padding: 1.2rem; border-left: 4px solid #ffc107; margin: 1.5rem 0; border-radius: 4px; color: #856404; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>🏗️ Architektur-Wissen:</strong> JSON unterscheidet strikt zwischen <strong>Objekten</strong> (eingefasst in geschweifte Klammern <code>{ }</code>) und <strong>Arrays/Listen</strong> (eingefasst in eckige Klammern <code>[ ]</code>). Dies spiegelt sich exakt in den SimpleJSON-Klassen <code>JSONObject</code> und <code>JSONArray</code> wider! Verwechsle sie beim Casten nicht.
</div>

<p>Gehen wir davon aus, wir erhalten folgenden JSON-String von einer API:</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, ''Courier New'', monospace; font-size: 0.9rem; line-height: 1.5;">{
  "embedded": {
    "notices": [
      {
        "name": "Müller",
        "forename": "Max",
        "date_of_birth": "1990-01-01",
        "_links": {
          "thumbnail": {
            "href": "https://beispiel.de/bild.jpg"
          }
        }
      }
    ]
  }
}</code></pre></div>

<p>Der dazugehörige, professionelle Java-Code zum Parsen sieht wie folgt aus:</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, ''Courier New'', monospace; font-size: 0.9rem; line-height: 1.5;">import org.json.simple.JSONArray;
import org.json.simple.JSONObject;
import org.json.simple.parser.JSONParser;
import java.util.ArrayList;

public class JsonHelper {

    // Nimmt einen reinen JSON-String entgegen und gibt eine Liste von Person-Objekten zurück
    private ArrayList&lt;Person&gt; parseJson(String jsonString) {
        ArrayList&lt;Person&gt; personList = new ArrayList&lt;&gt;();

        try {
            // 1. Parser instanziieren
            JSONParser parser = new JSONParser();
            
            // 2. Den String in ein generisches JSONObject umwandeln (Root-Ebene)
            JSONObject rootObject = (JSONObject) parser.parse(jsonString);
            
            // 3. Durch den Baum navigieren: Zuerst das Objekt, dann das Array
            JSONObject embedded = (JSONObject) rootObject.get("embedded");
            JSONArray notices = (JSONArray) embedded.get("notices");

            // 4. Über das Array iterieren und Java-Objekte bauen
            for (Object item : notices) {
                JSONObject notice = (JSONObject) item;
                
                String name = notice.get("name").toString();
                String forename = notice.get("forename").toString();
                String dob = notice.get("date_of_birth").toString();
                
                // Extraktion tief verschachtelter Daten (Defensive Programming mit Null-Checks)
                String imageUrl = null;
                JSONObject links = (JSONObject) notice.get("_links");
                if (links != null) {
                    JSONObject thumbnail = (JSONObject) links.get("thumbnail");
                    if (thumbnail != null) {
                        imageUrl = thumbnail.get("href").toString();
                    }
                }
                
                // 5. Unser Java-Objekt instanziieren und zur dynamischen Liste hinzufügen
                Person person = new Person(name, forename, dob, imageUrl);
                personList.add(person);
            }
        } catch (Exception e) {
            e.printStackTrace();
        }

        return personList;
    }
}</code></pre></div>', '', 'article', 'published', 63, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
