]', 'quiz', 'published', 94, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lhwrgzfxvlmgnnsa4ev', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Die Kostenfunktion & Beschäftigung', '
            <h3>1. Die lineare Kostenfunktion</h3>
            <p>Um Kosten planen zu können, zerlegen wir die Gesamtkosten (K) in zwei Blöcke: Kosten, die sich mit der Menge ändern (variabel) und Kosten, die gleich bleiben (fix).</p>

            <div style="background: #fff; border: 2px solid var(--secondary-color); padding: 1.5rem; text-align: center; border-radius: 8px; margin: 2rem 0; box-shadow: var(--shadow-sm);">
                <h2 style="margin:0; font-family: monospace; font-size: 2rem; color: var(--primary-color);">K(x) = k<sub>v</sub> · x + K<sub>f</sub></h2>
                <div style="margin-top: 15px; font-size: 0.9em; display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
                    <span style="background: #eee; padding: 2px 8px; border-radius: 4px;"><strong>K(x):</strong> Gesamtkosten</span>
                    <span style="background: #ffebee; color: #c0392b; padding: 2px 8px; border-radius: 4px;"><strong>k<sub>v</sub>:</strong> var. Stückkosten</span>
                    <span style="background: #eee; padding: 2px 8px; border-radius: 4px;"><strong>x:</strong> Menge</span>
                    <span style="background: #e3f2fd; color: #1976d2; padding: 2px 8px; border-radius: 4px;"><strong>K<sub>f</sub>:</strong> Fixkosten</span>
                </div>
            </div>

            <h3>2. Beispielrechnung: Schmolmann KG</h3>
            <p>Unternehmer Schmolmann ermittelt für seine Gehäuseproduktion folgende Werte:</p>
            <ul>
                <li>Fixkosten (Miete, Abschreibung): <strong>4.000.000 €</strong></li>
                <li>Variable Kosten bei 200.000 Stück: <strong>5.708.000 €</strong></li>
            </ul>

            <p><strong>Schritt 1: Variable Stückkosten ermitteln</strong><br>
            <code>k_v = 5.708.000 € / 200.000 Stk = 28,54 €/Stk</code></p>

            <p><strong>Schritt 2: Kostenfunktion aufstellen</strong><br>
            <code>K(x) = 28,54 · x + 4.000.000</code></p>

            <p><strong>Schritt 3: Prognose für 225.000 Stück</strong><br>
            <code>K(225.000) = 28,54 · 225.000 + 4.000.000 = 10.421.500,00 €</code></p>
        ', '', 'article', 'published', 41, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
