INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l4qfr36jz9grez2cohi', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Break-Even-Point (Gewinnschwelle)', '
            <h3>1. Die Gewinnschwellenmenge</h3>
            <p>Der Break-Even-Point ist die Stückzahl, bei der die Erlöse genau die Gesamtkosten decken. Der Gewinn ist 0.</p>
            
            <div style="background: #fff; border: 2px solid #2c3e50; padding: 1.5rem; text-align: center; border-radius: 8px; margin: 2rem 0;">
                <h3 style="margin:0; color: var(--primary-color);">Break-Even-Menge (x) = K<sub>f</sub> / db</h3>
                <p style="margin-top: 10px; color: #666;">Fixkosten geteilt durch Stückdeckungsbeitrag</p>
                <hr style="width: 50%; border: 0; border-top: 1px solid #eee; margin: 1rem auto;">
                <p><strong>Beispiel:</strong><br>
                4.000.000 € (Fixkosten) / 26,05 € (db) <br>
                = <strong>153.551 Stück</strong></p>
            </div>

            <h3>2. Grafische Analyse</h3>
            <p>Hier sehen wir den Schnittpunkt von Umsatz (Erlös) und Gesamtkosten. Alles rechts vom Punkt ist die <strong>Gewinnzone</strong>.</p>

            <!-- Responsive SVG Diagramm -->
            <div style="width: 100%; max-width: 700px; margin: 0 auto; background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 10px; box-shadow: var(--shadow-sm);">
                <svg viewBox="0 0 500 300" style="width: 100%; height: auto; font-family: sans-serif; font-size: 12px;">
                    <!-- Grid Lines -->
                    <line x1="50" y1="250" x2="480" y2="250" stroke="#333" stroke-width="2" /> <!-- X-Axis -->
                    <line x1="50" y1="250" x2="50" y2="20" stroke="#333" stroke-width="2" />   <!-- Y-Axis -->
                    
                    <!-- Fixkosten Linie (Blau, Horizontal) -->
                    <line x1="50" y1="180" x2="480" y2="180" stroke="#1976d2" stroke-width="2" stroke-dasharray="5,5" />
                    <text x="400" y="175" fill="#1976d2" font-weight="bold">Fixkosten (K_f)</text>

                    <!-- Gesamtkosten Linie (Rot, Steigend ab Fixkosten) -->
                    <line x1="50" y1="180" x2="480" y2="50" stroke="#c0392b" stroke-width="2" />
                    <text x="350" y="60" fill="#c0392b" font-weight="bold">Gesamtkosten K(x)</text>

                    <!-- Umsatz Linie (Grün, Steil steigend ab 0) -->
                    <line x1="50" y1="250" x2="480" y2="20" stroke="#2e7d32" stroke-width="2" />
                    <text x="80" y="80" fill="#2e7d32" font-weight="bold">Umsatz E(x)</text>

                    <!-- Break Even Point (Korrigiert auf Schnittpunkt) -->
                    <circle cx="351" cy="89" r="5" fill="#000" />
                    <line x1="351" y1="89" x2="351" y2="250" stroke="#666" stroke-dasharray="4,2" />
                    
                    <!-- Labels -->
                    <text x="360" y="85" font-weight="bold" font-size="14">Break-Even</text>
                    <text x="320" y="270">153.551 Stk</text>
                    
                    <!-- Zonen -->
                    <text x="150" y="220" fill="#c0392b" opacity="0.5" font-size="16" font-weight="bold">VERLUST</text>
                    <text x="400" y="220" fill="#2e7d32" opacity="0.5" font-size="16" font-weight="bold">GEWINN</text>
                </svg>
            </div>

            <div style="background: #f8f9fa; padding: 1.5rem; border-left: 4px solid var(--primary-color); margin-top: 2rem;">
                <strong>Wichtige Erkenntnisse:</strong>
                <ul>
                    <li>Liegt die Absatzmenge <strong>unter</strong> der Gewinnschwelle, macht das Unternehmen Verlust.</li>
                    <li>Jedes Stück, das <strong>über</strong> der Gewinnschwelle verkauft wird, bringt den vollen Deckungsbeitrag (26,05 €) als Reingewinn ein!</li>
                    <li>Eine Preiserhöhung senkt die Gewinnschwelle (man ist früher profitabel), birgt aber das Risiko von Absatzrückgang.</li>
                </ul>
            </div>
        ', '', 'article', 'published', 46, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
