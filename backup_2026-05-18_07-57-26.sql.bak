INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lx19bsb4zi2vomw1717', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Aufzählungstypen (Enums)', '<h3>1. Was ist ein Enum?</h3>
<p>Ein <code>enum</code> (kurz für <em>enumeration</em>) ist ein spezieller Datentyp in Java, der eine feste, vorgegebene Menge von Konstanten repräsentiert. Da Bezeichner von Konstanten in Java konventionell komplett großgeschrieben werden, gilt das auch für Enums.</p>

<div style="background: #fff3cd; padding: 1rem; border-left: 4px solid #ffc107; margin: 1.5rem 0; border-radius: 4px; color: #856404; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>💡 Warum Enums nutzen?</strong> Wenn man stattdessen normale Integers (z.B. <code>int day = 0;</code> für Montag) nutzt, schleichen sich schnell Fehler ein, da der Compiler nicht prüfen kann, ob "0" wirklich ein Wochentag ist. Enums garantieren <strong>Typsicherheit</strong>!
</div>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">public enum Wochentag {
    MONTAG, DIENSTAG, MITTWOCH, DONNERSTAG, FREITAG, SAMSTAG, SONNTAG
}</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Enums in Switch-Statements</h3>
<p>Enums eignen sich hervorragend für Fallunterscheidungen (<code>switch</code>), da der Compiler genau weiß, welche Fälle existieren können.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">Wochentag today = Wochentag.MONTAG;

// Moderne Switch-Syntax (ab Java 14)
switch (today) {
    case MONTAG -> System.out.println("Wochenanfang!");
    case FREITAG -> System.out.println("Fast Wochenende!");
    default -> System.out.println("Ein anderer Tag");
}</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Enums mit Konstruktoren und Methoden</h3>
<p>Enums sind in Java viel mächtiger als in vielen anderen Sprachen. Sie sind intern vollwertige Klassen und können Konstruktoren, eigene Felder und Methoden enthalten!</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">public enum Planet {
    // Die Konstanten definieren ihre Parameter direkt bei der Deklaration
    ERDE(5.97e24), 
    MARS(6.42e23);

    private final double mass;

    // Der Konstruktor (ist bei Enums implizit private)
    Planet(double mass) {
        this.mass = mass;
    }

    public double getMass() {
        return mass;
    }
}

// Verwendung:
Planet planet = Planet.ERDE;
System.out.println("Masse von " + planet + ": " + planet.getMass());</code></pre></div>', '', 'article', 'published', 64, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lx2vxzf8knzdpkrhm2k', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4F10 - Kapitel 2', '', '[
