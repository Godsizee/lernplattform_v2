INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l02piykrjt9iieom3qe', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Objektorientierung: Abstraktion & Interfaces', '<h3>1. Was ist Abstraktion?</h3>
<p>Bei der Datenabstraktion werden bestimmte Details ausgeblendet und dem Programmierer nur die wesentlichen Informationen gegeben. Das Konzept und die Umsetzung werden dabei streng getrennt.</p>
<div style="background: #fff3cd; padding: 1rem; border-left: 4px solid #ffc107; margin: 1.5rem 0; border-radius: 4px; color: #856404;">
    <strong>💡 Merke:</strong> Abstraktion zielt darauf ab, die Details der Implementierung zu verbergen und daraus ein allgemeines Lösungsschema abzuleiten. In Java wird dies hauptsächlich mittels <strong>abstrakter Klassen</strong> oder <strong>Schnittstellen (Interfaces)</strong> erreicht.
</div>

<h3>2. Mehrfachvererbung mit Interfaces</h3>
<p>Java unterstützt klassischerweise <strong>keine</strong> Mehrfachvererbung (eine Klasse kann nur von <em>einer</em> direkten Oberklasse erben). Mit Interfaces kann dieses Konzept jedoch elegant umgesetzt werden, da eine Klasse beliebig viele Interfaces implementieren darf.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, ''Courier New'', monospace; font-size: 0.95rem; line-height: 1.5;">interface Mammal {
    void eat();
}

interface Bird {
    void fly();
}

// Ein Animal kann mehrere Interfaces erben
interface Animal extends Mammal, Bird {
    void breathe();
}

// Konkrete Implementierung
class Dog implements Animal {
    @Override
    public void eat() { 
        System.out.println("Dog is eating"); 
    }
    
    @Override
    public void fly() { 
        System.out.println("Dog cannot fly"); 
    }
    
    @Override
    public void breathe() { 
        System.out.println("Dog is breathing"); 
    }
}</code></pre></div>', '', 'article', 'published', 58, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l06i4gbhx8vi6y485sc', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Datenaustauschformate: CSV, XML & JSON', '<h3>1. Die großen Drei der Web-Entwicklung</h3>
<p>Um Daten zwischen verschiedenen Systemen (z.B. Backend und Frontend) zu speichern und reibungslos auszutauschen, haben sich im Laufe der Jahre verschiedene strukturierte Formate etabliert.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    
    <!-- CSV Card -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #2980b9;">📊 CSV (Comma-Separated Values)</h4>
        <p style="color: #555; font-size: 0.9em;">Ein simples textbasiertes Format für tabellarische Daten. Jede Zeile ist ein Datensatz, getrennt durch ein Komma oder Semikolon.</p>
        <ul style="font-size: 0.85em; color: #444; padding-left: 1.2rem;">
            <li><strong style="color:#27ae60;">Vorteil:</strong> Sehr kompakt, nativ kompatibel mit Excel und Datenbanken.</li>
            <li><strong style="color:#c0392b;">Nachteil:</strong> Keine Verschachtelung oder Hierarchien möglich.</li>
        </ul>
        <div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1rem; border-radius: 6px; overflow-x: auto; margin-top: 10px;"><pre style="margin:0; font-size:0.85em;"><code style="font-family: ''Fira Code'', Consolas, monospace;">Name,Alter,Stadt
Max,25,Berlin</code></pre></div>
    </div>

    <!-- XML Card -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">📝 XML (Extensible Markup Language)</h4>
        <p style="color: #555; font-size: 0.9em;">Hierarchische Strukturierung mittels verschachtelter Tags (ähnelt stark dem Aufbau von HTML).</p>
        <ul style="font-size: 0.85em; color: #444; padding-left: 1.2rem;">
            <li><strong style="color:#27ae60;">Vorteil:</strong> Selbstbeschreibend, Validierung durch strenge Schemas möglich.</li>
            <li><strong style="color:#c0392b;">Nachteil:</strong> Sehr viel Text-Overhead (Dokumente werden schnell aufgebläht).</li>
        </ul>
        <div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1rem; border-radius: 6px; overflow-x: auto; margin-top: 10px;"><pre style="margin:0; font-size:0.85em;"><code style="font-family: ''Fira Code'', Consolas, monospace;">&lt;person&gt;
  &lt;name&gt;Max&lt;/name&gt;
&lt;/person&gt;</code></pre></div>
    </div>

    <!-- JSON Card -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f0fdf4; border-left: 4px solid #2ecc71; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #27ae60;">🚀 JSON (JavaScript Object Notation)</h4>
        <p style="color: #555; font-size: 0.9em;">Ein hochkompaktes Datenformat in einfach lesbarer Textform, basierend auf simplen Schlüssel-Wert-Paaren.</p>
        <ul style="font-size: 0.85em; color: #444; padding-left: 1.2rem;">
            <li><strong style="color:#27ae60;">Vorteil:</strong> Der absolute Standard für Web-APIs, leichtgewichtiger als XML.</li>
            <li><strong style="color:#c0392b;">Nachteil:</strong> Keine direkte Einbindung von Kommentaren vorgesehen.</li>
        </ul>
        <div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1rem; border-radius: 6px; overflow-x: auto; margin-top: 10px;"><pre style="margin:0; font-size:0.85em;"><code style="font-family: ''Fira Code'', Consolas, monospace;">{
  "name": "Max",
  "alter": 25
}</code></pre></div>
    </div>

</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Exkurs: Die Wohlgeformtheit von XML</h3>
<p>Damit ein XML-Dokument nicht crasht, muss es strengen syntaktischen Regeln folgen (die sogenannte Wohlgeformtheit):</p>

<ol style="background: #fff; padding: 1.5rem 2.5rem; border-radius: 8px; border: 1px solid #ddd; box-shadow: 0 4px 15px rgba(0,0,0,0.03); line-height: 1.7;">
    <li style="margin-bottom: 10px;"><strong>Genau ein Wurzelelement (Root):</strong> Das gesamte Dokument muss von exakt einem äußeren Element umschlossen sein.</li>
    <li style="margin-bottom: 10px;"><strong>Case-Sensitivity:</strong> Groß- und Kleinschreibung ist entscheidend! <code>&lt;Item&gt;</code> schließt sich <em>nicht</em> mit <code>&lt;/item&gt;</code>.</li>
    <li style="margin-bottom: 10px;"><strong>Hierarchische Schachtelung:</strong> Tags müssen in der exakt umgekehrten Reihenfolge geschlossen werden, in der sie geöffnet wurden (LIFO-Prinzip).</li>
    <li style="margin-bottom: 10px;"><strong>Attributwerte in Anführungszeichen:</strong> Müssen immer z.B. so formatiert sein: <code>&lt;element id="123"&gt;</code>.</li>
    <li><strong>Vordefinierte Entitäten maskieren:</strong> Sonderzeichen brechen den Code. Aus <code>&lt;</code> wird <code>&amp;lt;</code>, aus <code>&gt;</code> wird <code>&amp;gt;</code> und aus <code>&amp;</code> wird zwingend <code>&amp;amp;</code>.</li>
</ol>', '', 'article', 'published', 62, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l0bjafm0yze0m9sl6p5', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Praxis: Die OpenAI API Response parsen', '<h3>1. Die Antwort der KI strukturieren</h3>
<p>Haben wir erfolgreich einen POST-Request an z. B. OpenAI gesendet, erhalten wir im Response-Body einen großen JSON-String zurück. Dieser enthält viele Metadaten, aber uns interessiert meistens nur der generierte Text und eventuell die verwendeten Tokens.</p>

<p>Ein typischer Response-Ausschnitt von OpenAI sieht in etwa so aus:</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.85rem; line-height: 1.5;">{
  "id": "resp_684839e3a3708",
  "model": "gpt-4",
  "output": [
    {
      "role": "assistant",
      "content": [
        {
          "type": "output_text",
          "text": "In einem magischen Wald lebten die..."
        }
      ]
    }
  ]
}</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Das Record als Daten-Container</h3>
<p>Wir haben <em>Records</em> bereits kennengelernt. Sie sind perfekt, um dieses API-Ergebnis sauber zu speichern, damit unsere Anwendung (z. B. JavaFX) es bequem weiterverarbeiten kann.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #3498db; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">// Unser Daten-Container für das Ergebnis
public record GPTResponse(String id, String text) {}</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Das JSON mit SimpleJSON parsen</h3>
<p>Jetzt durchlaufen wir mit dem <code>JSONParser</code> den empfangenen Baum. Da OpenAI den Text tief in Arrays verschachtelt, müssen wir uns Schritt für Schritt vorarbeiten (Objekt &rarr; Array &rarr; Objekt &rarr; Array &rarr; String).</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #2ecc71; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">import org.json.simple.JSONArray;
import org.json.simple.JSONObject;
import org.json.simple.parser.JSONParser;

public class OpenAIParser {

    public GPTResponse parseGPTResponse(String jsonString) {
        try {
            JSONParser parser = new JSONParser();
            
            // 1. String in Root-Objekt wandeln
            JSONObject root = (JSONObject) parser.parse(jsonString);
            
            // 2. Metadaten holen
            String id = root.get("id").toString();
            
            // 3. Tief absteigen: Erst in das Array "output"
            JSONArray outputArray = (JSONArray) root.get("output");
            if (outputArray != null && !outputArray.isEmpty()) {
                
                // Wir holen das erste Element der Antwort
                JSONObject firstOutput = (JSONObject) outputArray.get(0);
                
                // Darin liegt das "content" Array
                JSONArray contentArray = (JSONArray) firstOutput.get("content");
                if (contentArray != null && !contentArray.isEmpty()) {
                    
                    // Daraus das erste Text-Objekt holen
                    JSONObject contentObject = (JSONObject) contentArray.get(0);
                    
                    // Endlich: Den eigentlichen Text extrahieren!
                    String generatedText = contentObject.get("text").toString();
                    
                    // Record instanziieren und zurückgeben
                    return new GPTResponse(id, generatedText);
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        
        // Fallback, wenn etwas schiefgeht
        return new GPTResponse("error", "Fehler beim Auslesen des JSON.");
    }
}</code></pre></div>', '', 'article', 'published', 71, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l0ekbkdvl2bm7fq7n53', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'Constraints: Die Türsteher der Datenbank', '<h3>1. Was sind Constraints?</h3>
<p>Datentypen verhindern zwar, dass wir Text in einem Zahlenfeld speichern, sie verhindern aber nicht, dass z.B. das Alter eines Kunden auf <code>-50</code> Jahre gesetzt wird oder eine E-Mail-Adresse doppelt im System landet. Hier kommen <strong>Constraints (Einschränkungen/Regeln)</strong> ins Spiel. Sie erzwingen die logische Datenintegrität auf Ebene des DBMS.</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 1.5rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 0.95rem; border-radius: 8px; overflow: hidden;">
    <thead>
        <tr style="background: linear-gradient(135deg, #2c3e50, #34495e); color: #fff;">
            <th style="padding: 15px; text-align: left; width: 25%;">Constraint</th>
            <th style="padding: 15px; text-align: left; width: 75%;">Wirkung & Praxisbeispiel</th>
        </tr>
    </thead>
    <tbody>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #c0392b; font-family: monospace;">PRIMARY KEY</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Definiert den eindeutigen Schlüssel der Tabelle. Erlaubt keine doppelten Werte und verbietet leere Zellen (NULL). Eine Tabelle kann nur einen Primärschlüssel haben.</td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #2980b9; font-family: monospace;">FOREIGN KEY</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Sichert die referentielle Integrität ab. Erlaubt in einer Spalte nur Werte, die im Primärschlüssel der verknüpften Tabelle tatsächlich existieren.</td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #e67e22; font-family: monospace;">UNIQUE</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Stellt sicher, dass alle Werte in einer Spalte unterschiedlich sind. Perfekt für Felder wie <code>email</code> oder <code>benutzername</code>. Im Gegensatz zum Primärschlüssel darf eine Tabelle beliebig viele UNIQUE-Constraints haben.</td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #8e44ad; font-family: monospace;">NOT NULL</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Erzwingt, dass dieses Feld bei der Dateneingabe zwingend ausgefüllt werden muss (Darf nicht leer gelassen werden). Sinnvoll für Felder wie <code>nachname</code>.</td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; font-weight: bold; color: #27ae60; font-family: monospace;">CHECK</td>
            <td style="padding: 15px; color: #333;">Überprüft eine logische Bedingung vor dem Speichern. Zum Beispiel: <code>CHECK (alter >= 18)</code> oder <code>CHECK (preis > 0)</code>. Schlägt die Prüfung fehl, wird die Speicherung hart blockiert.</td>
        </tr>
    </tbody>
</table>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #2ecc71; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.6;">-- Ein perfektes Praxisbeispiel für Constraints
CREATE TABLE produkte (
    produkt_id SERIAL PRIMARY KEY,
    bezeichnung VARCHAR(100) NOT NULL UNIQUE,
    preis DECIMAL(10,2) NOT NULL CHECK (preis > 0),
    kategorie_id INT,
    FOREIGN KEY (kategorie_id) REFERENCES kategorien(kategorie_id)
);</code></pre></div>', '', 'article', 'published', 13, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l0mfwbi4992cj2yqgyi', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4500 - Kapitel 4', '', '[
    {
        "chapter": 4,
        "question": "14. Welche der folgenden Objekte werden durch Geschäftspartner-Stammdaten dargestellt?",
        "type": "checkbox",
        "options": {
            "A": "Dispositionsbereich",
            "B": "Lieferant",
            "C": "Lagerort",
            "D": "Kunde"
        },
        "correct": [
            "B",
            "D"
        ],
        "link": "s4500.php#lektion-4-1"
    },
    {
        "chapter": 4,
        "question": "15. Welche Organisationsebenen sind bei der Pflege eines Geschäftspartners mit den Lieferanten- und Kreditorenrollen relevant?",
        "type": "checkbox",
        "options": {
            "A": "Einkaufsorganisation",
            "B": "Lagerort",
            "C": "Einkäufergruppe",
            "D": "Buchungskreis"
        },
        "correct": [
            "A",
            "D"
        ],
        "link": "s4500.php#lektion-4-1"
    },
    {
        "chapter": 4,
        "question": "16. Welche der folgenden Sichten können in einem Materialstammsatz angelegt werden?",
        "type": "checkbox",
        "options": {
            "A": "Einkaufsorganisationsdaten",
            "B": "Buchhaltung",
            "C": "Vertrieb",
            "D": "Bezugsquellen",
            "E": "Prognose"
        },
        "correct": [
            "A",
            "B",
            "C",
            "E"
        ],
        "link": "s4500.php#lektion-4-2"
    },
    {
        "chapter": 4,
        "question": "17. Beim Anlegen eines Materialstammsatzes müssen Sie eine Materialart angeben. Was steuert die Materialart?",
        "type": "checkbox",
        "options": {
            "A": "Die Art der Nummernvergabe",
            "B": "Die zulässige Länge des Materialkurztextes",
            "C": "Ob ein Material bestellt werden darf",
            "D": "Welche Sichten gepflegt werden können"
        },
        "correct": [
            "A",
            "C",
            "D"
        ],
        "link": "s4500.php#lektion-4-2"
    },
    {
        "chapter": 4,
        "question": "18. Wenn Sie einen Materialstammsatz um eine Sicht erweitern möchten, müssen Sie den Materialstammsatz ändern.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "B"
        ],
        "link": "s4500.php#lektion-4-2"
    },
    {
        "chapter": 4,
        "question": "19. Um welche Art von Daten handelt es sich bei einem Einkaufsinfosatz?",
        "type": "radio",
        "options": {
            "A": "Bewegungsdaten",
            "B": "Customizing-Einstellung",
            "C": "Stammdaten",
            "D": "Meldedaten"
        },
        "correct": [
            "C"
        ],
        "link": "s4500.php#lektion-4-3"
    },
    {
        "chapter": 4,
        "question": "20. Welche der folgenden Organisationsebenen sind für Einkaufsinfosätze relevant?",
        "type": "checkbox",
        "options": {
            "A": "Mandant",
            "B": "Buchungskreis",
            "C": "Werk",
            "D": "Lagerort",
            "E": "Einkaufsorganisation"
        },
        "correct": [
            "A",
            "C",
            "E"
        ],
        "link": "s4500.php#lektion-4-3"
    },
    {
        "chapter": 4,
        "question": "21. Welche der folgenden Aussagen über die Bewertungsklasse sind richtig?",
        "type": "checkbox",
        "options": {
            "A": "Anhand der Bewertungsklasse wird ermittelt, welches Bestandskonto bei einer Warenbewegung eines Materials fortgeschrieben wird.",
            "B": "Die Bewertungsklasse ist ein Gruppierungsschlüssel, der steuert, nach welchem Verfahren ein Material bewertet wird.",
            "C": "Über die Wahl der Bewertungsklasse entscheiden Sie, ob für ein Material Einkaufskonditionen auf Werksebene zulässig sind.",
            "D": "Die Bewertungsklasse ermöglicht es, die Bestände mehrerer Materialien auf einem Bestandskonto zu führen."
        },
        "correct": [
            "A",
            "D"
        ],
        "link": "s4500.php#lektion-4-4"
    },
    {
        "chapter": 4,
        "question": "22. Welche Art von Buchung erfolgt in der Finanzbuchhaltung bei der Umlagerung eines Rohstoffs innerhalb eines Werkes?",
        "type": "radio",
        "options": {
            "A": "Eine Preisdifferenzbuchung wird durchgeführt.",
            "B": "Keine Buchung wird durchgeführt.",
            "C": "Nur Buchhaltungsbelege werden fortgeschrieben.",
            "D": "Ein neues Konto wird angelegt."
        },
        "correct": [
            "B"
        ],
        "link": "s4500.php#lektion-4-4"
    },
    {
        "chapter": 4,
        "question": "23. Sie haben ein Material für das Lager bestellt, das zum Standardpreis (Preissteuerung S) bewertet wird. Was geschieht, wenn Sie den Wareneingang für diese Bestellung buchen?",
        "type": "checkbox",
        "options": {
            "A": "Unterscheidet sich der Bestellpreis vom Standardpreis, wird diese Differenz direkt auf das Bestandskonto gebucht.",
            "B": "Die Bestandsbuchung erfolgt zu dem im Materialstammsatz hinterlegten Standardpreis.",
            "C": "Der Standardpreis im Materialstammsatz wird an den Bestellpreis angepasst.",
            "D": "Der Gesamtbestand im Materialstammsatz wird um die Wareneingangsmenge erhöht."
        },
        "correct": [
            "B",
            "D"
        ],
        "link": "s4500.php#lektion-4-4-standardpreis"
    },
    {
        "chapter": 4,
        "question": "24. Sie haben ein Material für das Lager bestellt, das zum gleitenden Durchschnittspreis (Preissteuerung V) bewertet wird. Was geschieht, wenn Sie den Wareneingang für diese Bestellung buchen?",
        "type": "checkbox",
        "options": {
            "A": "Die Bestandsbuchung erfolgt zum Bestellpreis.",
            "B": "Der Gesamtbestand im Materialstammsatz wird um die Wareneingangsmenge erhöht.",
            "C": "Der gleitende Durchschnittspreis im Materialstammsatz wird basierend auf dem neuen Bestandswert und dem neuen Gesamtbestand neu berechnet.",
            "D": "Der gleitende Durchschnittspreis wird nach folgender Formel berechnet: Gesamtbestand\\/Gesamtwert."
        },
        "correct": [
            "A",
            "B",
            "C"
        ],
        "link": "s4500.php#lektion-4-4-gleitender-preis"
    }
]', 'quiz', 'published', 99, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l0t0n5zghuti9yp48q8', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4600 - Kapitel 6', '', '[
