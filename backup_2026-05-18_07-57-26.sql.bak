]', 'quiz', 'published', 86, '2026-05-04 08:39:56', '2026-05-04 08:39:56');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lmjdowp2siag3ehrj6j', 'sxh3e5ewi0qahenr6jg', 'u5ilhtdcn9ycti9tbmc', '3. Datenmodellierung (ABAP Dictionary)', '<div style="margin-bottom: 3rem;">
    <span style="display: inline-block; padding: 0.35rem 1rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1.5rem; background: rgba(6, 182, 212, 0.15); border: 1px solid rgba(6, 182, 212, 0.3); color: #22d3ee;">Data Dictionary</span>
    <h1 style="font-size: 2.5rem; font-weight: 800; color: #f8fafc; margin-bottom: 1.5rem; letter-spacing: -0.025em;">Das Domainenkonzept</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
        <div style="background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1.5rem; padding: 2.5rem; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);">
            <h3 style="font-size: 1.25rem; font-weight: 700; color: #8b5cf6; margin-bottom: 1.25rem;">Domain (Technik)</h3>
            <p style="font-size: 0.95rem; color: #94a3b8; margin-bottom: 1.5rem; line-height: 1.6;">Dient dazu, technische Eigenschaften zentral zu definieren.</p>
            <ul style="list-style: none; padding: 0; margin: 0 0 1.5rem 0; color: #cbd5e1; font-size: 0.95rem; line-height: 1.7;">
                <li><strong style="color: #64748b; margin-right: 0.5rem;">•</strong> Definiert Datentyp (z.B. CHAR)</li>
                <li><strong style="color: #64748b; margin-right: 0.5rem;">•</strong> Definiert Länge und Dezimalstellen</li>
                <li><strong style="color: #64748b; margin-right: 0.5rem;">•</strong> <strong style="color: #ec4899;">Festwerte:</strong> Definition erlaubter Werte</li>
            </ul>
        </div>

        <div style="background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 1.5rem; padding: 2.5rem; box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);">
            <h3 style="font-size: 1.25rem; font-weight: 700; color: #ec4899; margin-bottom: 1.5rem;">Datenelement (Semantik)</h3>
            <ul style="list-style: none; padding: 0; margin: 0 0 2rem 0; color: #cbd5e1; line-height: 1.6; font-size: 0.95rem;">
                <li style="display: flex; align-items: flex-start; margin-bottom: 1rem;">
                    <span style="color: #ec4899; font-weight: 800; margin-right: 0.75rem;">→</span> 
                    <span>Verweist auf eine Domäne (erbt die Technik)</span>
                </li>
                <li style="display: flex; align-items: flex-start;">
                    <span style="color: #ec4899; font-weight: 800; margin-right: 0.75rem;">→</span> 
                    <span>Definiert die semantische Bedeutung (Bezeichnung, Doku)</span>
                </li>
            </ul>
            <div style="background: rgba(6, 182, 212, 0.05); border: 1px solid rgba(6, 182, 212, 0.2); border-radius: 0.75rem; padding: 1rem;">
                <p style="font-size: 0.85rem; color: #cbd5e1; margin: 0; font-style: italic;">Felder in Tabellen verweisen beim Design <strong>immer auf Datenelemente</strong>, niemals direkt auf die Domäne!</p>
            </div>
        </div>
    </div>
</div>', '', 'article', 'published', 49, '2026-04-28 19:54:37', '2026-04-28 19:54:37');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lmsg9pd4k2d3a54zgpe', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4500 - Kapitel 6', '', '[
    {
        "chapter": 6,
        "question": "33. Wie können Sie mit der App Meine Bestellanforderungen - Neu eine neue Bestellanforderungsposition anlegen?",
        "type": "checkbox",
        "options": {
            "A": "Sie geben die Nummer eines Materialstammsatzes ein.",
            "B": "Sie geben eine Beschreibung für das benötigte Produkt ein, wenn es nicht in einem Katalog enthalten ist.",
            "C": "Sie importieren eine Excel-Liste mit Materialnummern.",
            "D": "Sie wählen das Material aus einem Katalog aus."
        },
        "correct": [
            "A",
