INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lo1tw0ronxubd8aqjvi', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Grundlagen der Sortieralgorithmen', '<h3>1. Kriterien zur Einordnung</h3>
<p>Es gibt unzählige Algorithmen, um Daten zu sortieren. Welcher der beste ist, hängt stark vom jeweiligen Anwendungsfall ab. Wir ordnen sie nach drei Hauptkriterien ein:</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #2980b9;">⏱️ Zeitkomplexität</h4>
        <p style="color: #555; font-size: 0.9rem;">Wie viele Durchläufe/Operationen werden bei einer Menge von <code>n</code> Elementen benötigt? Gemessen in der <strong>Landau-Notation</strong> (z.B. <code>O(n²)</code> oder <code>O(n log n)</code>). Wir unterscheiden in <em>Best Case</em>, <em>Average Case</em> und <em>Worst Case</em>.</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">💾 Platzkomplexität</h4>
        <p style="color: #555; font-size: 0.9rem;">Wie viel <strong>zusätzlicher Arbeitsspeicher</strong> (RAM) wird während des Sortiervorgangs neben der eigentlichen Datenstruktur noch benötigt?</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f0fdf4; border-left: 4px solid #2ecc71; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #27ae60;">⚖️ Stabilität</h4>
        <p style="color: #555; font-size: 0.9rem;">Behält der Algorithmus die relative Ordnung von Elementen mit <strong>gleichen Schlüsseln</strong> bei? (Z.B. wenn eine Liste bereits alphabetisch sortiert ist und danach nach dem Geburtsjahr sortiert wird, bleiben gleichalte Personen alphabetisch geordnet?).</p>
    </div>
</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Die "Großen Zwei": Merge Sort & Quick Sort</h3>
<p>Einfache Algorithmen wie <em>Bubble Sort</em> sind leicht zu implementieren, aber für große Datensätze extrem ineffizient (meist <code>O(n²)</code>). Moderne Standardbibliotheken setzen daher oft auf <strong>Divide-and-Conquer</strong>-Verfahren (Teile und Herrsche).</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 0.95rem; border-radius: 8px; overflow: hidden;">
    <thead>
        <tr style="background: linear-gradient(135deg, #2c3e50, #34495e); color: #fff;">
            <th style="padding: 15px; text-align: left; width: 50%;">Merge Sort</th>
            <th style="padding: 15px; text-align: left; width: 50%;">Quick Sort</th>
        </tr>
    </thead>
    <tbody>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; border-right: 1px solid #eee; vertical-align: top;">
                <strong>Funktionsweise:</strong> Teilt die Liste rekursiv in der Mitte, bis nur noch Einzelelemente übrig sind. Diese werden dann sortiert wieder verschmolzen ("merged").
            </td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; vertical-align: top;">
                <strong>Funktionsweise:</strong> Bestimmt ein "Pivot-Element" und teilt die Liste in Werte kleiner und größer als das Pivot. Wird dann rekursiv auf die Teillisten angewendet.
            </td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; border-right: 1px solid #eee; color: #27ae60; font-weight: bold;">Zeitkomplexität: O(n log n)</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #27ae60; font-weight: bold;">Zeitkomplexität: O(n log n)</td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-right: 1px solid #eee;">Benötigt meist mehr Platzkomplexität (zusätzlicher Speicher für das Mergen).</td>
            <td style="padding: 15px;">In der Regel Standard-Algorithmus in Frameworks. Hohe Effizienz in der Praxis.</td>
        </tr>
    </tbody>
</table>', '', 'article', 'published', 65, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
