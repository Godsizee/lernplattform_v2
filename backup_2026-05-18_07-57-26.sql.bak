                    <tr>
                        <td style="padding: 4px 24px;">Leverkusener Kreditbank</td>
                        <td style="padding: 4px 8px; text-align: right;">590.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                    <tr>
                        <td style="padding: 4px 24px;">Deutsche Bank, Leverkusen</td>
                        <td style="padding: 4px 8px; text-align: right; border-bottom: 1px solid #ccc;">326.000,00</td>
                        <td style="padding: 4px 8px; text-align: right;">916.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">8. Kassenbestand</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px; text-align: right; border-bottom: 1px solid #ccc;">27.000,00</td>
