INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ludgy1o6ecc8pbmj6w6', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'Umsatzsteuer & Vorsteuer', '
            <h3>1. Das System der Mehrwertsteuer</h3>
            <p>Die Umsatzsteuer ist für Unternehmen ein <strong>durchlaufender Posten</strong>. Sie wird vom Endverbraucher getragen. Auf jeder Stufe der Wertschöpfungskette wird nur der geschaffene <strong>Mehrwert</strong> besteuert (Allphasen-Netto-Umsatzsteuer mit Vorsteuerabzug).</p>

            <div style="overflow-x: auto; margin: 1.5rem 0; border: 1px solid #dee2e6; border-radius: 8px;">
                <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
                    <tr style="background: var(--primary-color); color: white;">
                        <th style="padding: 12px; text-align: left;">Umsatzstufe</th>
                        <th style="padding: 12px; text-align: right;">Einkauf (netto)</th>
                        <th style="padding: 12px; text-align: right;">Verkauf (netto)</th>
                        <th style="padding: 12px; text-align: right;">Mehrwert</th>
                        <th style="padding: 12px; text-align: right;">Zahllast (19%)</th>
                    </tr>
                    <tr style="background: #f8f9fa;">
                        <td style="padding: 10px;">1. Forstbetrieb</td>
                        <td style="padding: 10px; text-align: right;">0,00 €</td>
                        <td style="padding: 10px; text-align: right;">2.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">2.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">380,00 €</td>
                    </tr>
                    <tr>
                        <td style="padding: 10px;">2. Möbelwerke</td>
                        <td style="padding: 10px; text-align: right;">2.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">6.500,00 €</td>
                        <td style="padding: 10px; text-align: right;">4.500,00 €</td>
                        <td style="padding: 10px; text-align: right;">855,00 €</td>
                    </tr>
                    <tr style="background: #f8f9fa;">
                        <td style="padding: 10px;">3. Großhandel</td>
                        <td style="padding: 10px; text-align: right;">6.500,00 €</td>
                        <td style="padding: 10px; text-align: right;">8.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">1.500,00 €</td>
                        <td style="padding: 10px; text-align: right;">285,00 €</td>
                    </tr>
                    <tr>
                        <td style="padding: 10px;">4. Einzelhandel</td>
                        <td style="padding: 10px; text-align: right;">8.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">10.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">2.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">380,00 €</td>
                    </tr>
                    <tr style="background: #2c3e50; color: white; font-weight: bold;">
                        <td style="padding: 10px;">Gesamt</td>
                        <td style="padding: 10px; text-align: right;"></td>
                        <td style="padding: 10px; text-align: right;">11.900,00 € (Brutto)</td>
                        <td style="padding: 10px; text-align: right;">10.000,00 €</td>
                        <td style="padding: 10px; text-align: right;">1.900,00 €</td>
                    </tr>
                </table>
            </div>

            <h3>2. Vorsteuer vs. Umsatzsteuer</h3>
            <p>Unternehmen unterscheiden zwischen der Steuer, die sie selbst zahlen (Einkauf) und der Steuer, die sie einnehmen (Verkauf).</p>

            <div style="display: flex; gap: 2rem; margin: 2rem 0; flex-wrap: wrap;">
                <div style="flex: 1; background: #e3f2fd; padding: 1.5rem; border-radius: 8px; border-left: 5px solid #2196f3;">
                    <h4 style="color: #1565c0; margin-top: 0;">Vorsteuer (Einkauf)</h4>
                    <p>Steuer auf Eingangsrechnungen.</p>
                    <ul>
                        <li><strong>Art:</strong> Forderung an das Finanzamt</li>
                        <li><strong>Konto:</strong> Aktivkonto</li>
                        <li><strong>Buchung:</strong> Im Soll</li>
                    </ul>
                </div>
                <div style="flex: 1; background: #ffebee; padding: 1.5rem; border-radius: 8px; border-left: 5px solid #c62828;">
                    <h4 style="color: #b71c1c; margin-top: 0;">Umsatzsteuer (Verkauf)</h4>
                    <p>Steuer auf Ausgangsrechnungen.</p>
                    <ul>
                        <li><strong>Art:</strong> Verbindlichkeit gegenüber Finanzamt</li>
                        <li><strong>Konto:</strong> Passivkonto</li>
                        <li><strong>Buchung:</strong> Im Haben</li>
                    </ul>
                </div>
            </div>

            <h3>3. Buchungssätze</h3>
            
            <div style="background: #fff; border: 1px solid #ccc; border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem;">
                <h4>A. Einkauf von Rohstoffen (Eingangsrechnung)</h4>
                <p>Nettowert: 2.000 € + 19% USt (380 €) = 2.380 € Brutto</p>
                <code style="display: block; background: #f8f9fa; padding: 10px; border-left: 3px solid #2c3e50;">
                    Rohstoffe 2.000,00<br>
                    Vorsteuer 380,00<br>
                    &nbsp;&nbsp;an Verbindlichkeiten a.LL 2.380,00
                </code>
            </div>

            <div style="background: #fff; border: 1px solid #ccc; border-radius: 8px; padding: 1.5rem;">
                <h4>B. Verkauf eigener Erzeugnisse (Ausgangsrechnung)</h4>
                <p>Nettowert: 6.500 € + 19% USt (1.235 €) = 7.735 € Brutto</p>
                <code style="display: block; background: #f8f9fa; padding: 10px; border-left: 3px solid #2c3e50;">
                    Forderungen a.LL 7.735,00<br>
                    &nbsp;&nbsp;an Umsatzerlöse f. eig. Erz. 6.500,00<br>
                    &nbsp;&nbsp;an Umsatzsteuer 1.235,00
                </code>
            </div>

            <h3>4. Ermittlung der Zahllast und Abschluss</h3>
            <p>Am Monatsende (bzw. Quartalsende) werden Vorsteuer und Umsatzsteuer verrechnet. Die Differenz ist die <strong>Zahllast</strong> (an das Finanzamt zu zahlen) oder ein <strong>Vorsteuerüberhang</strong> (Erstattung vom Finanzamt).</p>

            <div style="background: #fff9c4; padding: 1rem; border-radius: 4px; text-align: center; margin: 1rem 0; font-weight: bold; border: 1px solid #fbc02d;">
                Umsatzsteuer (Schuld) - Vorsteuer (Guthaben) = Zahllast
            </div>

            <h4>Schritt 1: Vorsteuerkonto abschließen</h4>
            <p>Der Saldo des Vorsteuerkontos (380 €) wird auf das Umsatzsteuerkonto umgebucht.</p>
            <p><code>Umsatzsteuer 380,00 an Vorsteuer 380,00</code></p>

            <h4>Schritt 2: Zahllast ermitteln (im Umsatzsteuerkonto)</h4>
            
            <div style="display: flex; justify-content: center; margin: 1.5rem 0;">
                <div style="min-width: 400px; border: 1px solid #333; background: #fff; padding: 10px;">
                    <div style="text-align: center; border-bottom: 2px solid #333; font-weight: bold; margin-bottom: 10px;">Umsatzsteuer</div>
                    <div style="display: flex; justify-content: space-between;">
                        <div style="width: 50%; border-right: 1px solid #ccc; padding-right: 10px;">
                            <strong>Soll</strong><br>
                            Vorsteuer: 380,00<br>
                            <span style="color: #c0392b; font-weight: bold;">Saldo (Zahllast): 855,00</span>
                        </div>
                        <div style="width: 50%; padding-left: 10px;">
                            <strong>Haben</strong><br>
                            Forderungen: 1.235,00<br>
                            (aus Verkauf)
                        </div>
                    </div>
                </div>
            </div>

            <h4>Schritt 3: Überweisung an das Finanzamt</h4>
            <p><code>Umsatzsteuer 855,00 an Bank 855,00</code></p>
            
            <p style="font-size: 0.9em; color: #666; margin-top: 1rem;">
                <em>Hinweis zur Bilanzierung:</em> Besteht am Jahresende noch eine Zahllast, wird diese als „Sonstige Verbindlichkeit“ passiviert. Ein Vorsteuerüberhang wird als „Sonstige Forderung“ aktiviert.
            </p>
        ', '', 'article', 'published', 31, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ludnn2ct4n5kgeteczl', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4550 - Kapitel 2', '', '[
