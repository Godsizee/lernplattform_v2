INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l543soy2pazium3kvg6', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Sichere Null-Behandlung: Optionals (Java 8+)', '<h3>1. Der Kampf gegen die NullPointerException</h3>
<p>Früher (vor Java 8) mussten Entwickler unzählige <code>if (obj != null)</code> Prüfungen schreiben, um gefürchtete <em>NullPointerExceptions</em> zu vermeiden. Das machte den Code unleserlich und fehleranfällig.</p>

<div style="background: #fffaf0; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #f39c12; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <h4 style="margin-top:0; color: #d35400;">📦 Die Lösung: Optional&lt;T&gt;</h4>
    <p style="margin: 0; color: #555;">Ein <code>Optional</code> ist ein spezieller Container. Er enthält entweder ein Objekt vom Typ T, oder er signalisiert ausdrücklich die "Abwesenheit" eines Wertes. Der Entwickler wird durch den Compiler regelrecht <strong>gezwungen</strong>, den leeren Fall zu behandeln!</p>
</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Das Elegante Fallback-Verhalten</h3>
<p>Statt klassischer IF-Abfragen bietet Optional brillante Methoden, um Fallbacks zu definieren:</p>

<table style="width: 100%; border-collapse: collapse; margin-top: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 0.95rem; border-radius: 8px; overflow: hidden;">
    <thead>
        <tr style="background: linear-gradient(135deg, #2c3e50, #34495e); color: #fff;">
            <th style="padding: 15px; text-align: left; width: 35%;">Methode</th>
            <th style="padding: 15px; text-align: left; width: 65%;">Wirkung</th>
        </tr>
    </thead>
    <tbody>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #a972ff; font-family: monospace;">.orElse(default)</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Liefert sofort den festgelegten <code>default</code>-Wert, falls der Container leer ist.</td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #a972ff; font-family: monospace;">.orElseGet(Supplier)</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Wie <code>orElse</code>, aber der Fallback-Wert wird <strong>nur bei tatsächlichem Bedarf</strong> berechnet (performanter bei komplexen Fallbacks).</td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #a972ff; font-family: monospace;">.orElseThrow()</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Wirft eine vordefinierte <code>Exception</code>, falls kein Wert im Container liegt.</td>
        </tr>
        <tr>
            <td style="padding: 15px; font-weight: bold; color: #a972ff; font-family: monospace;">.ifPresent(Lambda)</td>
            <td style="padding: 15px; color: #333;">Führt den übergebenen Code-Block <strong>nur dann</strong> aus, wenn ein Wert vorhanden ist.</td>
        </tr>
    </tbody>
</table>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Praxisbeispiel: ifPresent</h3>
<p>Wenn unser Repository (Datenbank) statt <code>null</code> nun ein <code>Optional&lt;Article&gt;</code> zurückgibt, können wir die Existenz in einem sauberen Einzeiler verarbeiten:</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">public class Main {
    public static void main(String[] args) {
        ArticleDAO articles = new ArticleDAO();
        
        // getArticleById gibt nun ein Optional&lt;Article&gt; zurück!
        Optional&lt;Article&gt; art1 = articles.getArticleById("UW7698998");

        // Wenn ein Wert da ist, iteriere in das Lambda ("value")
        art1.ifPresent(value -> {
            System.out.println("Gefundener Name: " + value.name());
            System.out.println("Aktueller Preis: " + value.price() + " €");
        });
        
        // Elegantes Laden mit Fallback Exception
        // Article sichererArtikel = art1.orElseThrow(() -> new RuntimeException("Artikel fehlt!"));
    }
}</code></pre></div>', '', 'article', 'published', 54, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l5msm0f22axmqm0clxg', 'sc65ozlek3mbpfnrwg4', 'u5ilhtdcn9ycti9tbmc', 'KLR Grundlagen', '
            <h3>Abgrenzung</h3>
            <ul>
                <li><strong>Finanzbuchhaltung:</strong> Aufwand / Ertrag (Gesamtunternehmen).</li>
                <li><strong>KLR:</strong> Kosten / Leistungen (Betriebszweckbezogen).</li>
            </ul>
        ', '', 'article', 'published', 36, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l6h2objwikzkxxiz24f', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'Datenbank-Design: Anomalien (Die dunkle Seite)', '<h3>1. Was passiert bei schlechtem Tabellendesign?</h3>
<p>Wenn man im relationalen Datenmodell alle Daten einfach blind in eine riesige, einzige Tabelle (eine sogenannte <em>Universalrelation</em>) stopft, entstehen gravierende Fehler bei der täglichen Arbeit. Diese logischen Design-Fehler nennt man <strong>Anomalien</strong>.</p>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Die drei klassischen Anomalien</h3>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    
    <!-- Update-Anomalie -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">📝 Update-Anomalie (Änderung)</h4>
        <p style="color: #555; font-size: 0.9rem;"><strong>Das Problem:</strong> Ein Kunde zieht um. Da seine Daten aber in 20 verschiedenen Bestell-Zeilen stehen, muss die Adresse 20 Mal geändert werden. Wird nur eine Zeile vergessen, ist die Datenbank widersprüchlich (inkonsistent).</p>
    </div>

    <!-- Delete-Anomalie -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fef2f2; border-left: 4px solid #e74c3c; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #c0392b;">🗑️ Delete-Anomalie (Löschung)</h4>
        <p style="color: #555; font-size: 0.9rem;"><strong>Das Problem:</strong> Ein Student meldet sich von seinem einzigen und letzten Kurs ab. Wenn wir die Kurs-Belegung löschen, löschen wir versehentlich auch den Namen und die Adresse des Studenten aus der Datenbank, da alles in einer Zeile stand!</p>
    </div>

    <!-- Insert-Anomalie -->
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #2980b9;">➕ Insert-Anomalie (Einfügung)</h4>
        <p style="color: #555; font-size: 0.9rem;"><strong>Das Problem:</strong> Wir wollen ein neues Produkt in den Katalog aufnehmen. Das geht aber nicht, weil noch kein Kunde dieses Produkt bestellt hat (und die Kunden-ID Teil des Primärschlüssels unserer riesigen Tabelle ist, der nicht NULL sein darf).</p>
    </div>

</div>

<div style="background: #fff3cd; padding: 1.2rem; border-left: 4px solid #ffc107; margin: 2rem 0; border-radius: 4px; color: #856404; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>💡 Die Lösung:</strong> Um diese Anomalien zu verhindern, müssen große Tabellen in kleinere, logisch getrennte Tabellen aufgeteilt werden. Diesen Prozess nennt man <strong>Normalisierung</strong>.
</div>', '', 'article', 'published', 7, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l6kfprp6n0azq0w7sqz', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'DDL: Tabellen erstellen (CREATE TABLE)', '<h3>1. Der Bauplan der Datenbank</h3>
<p>Mit der Data Definition Language (DDL) erschaffen wir das physische Fundament unserer Datenbank. Der wichtigste Befehl hierfür ist <code>CREATE TABLE</code>. Hiermit legen wir die Struktur, die Datentypen und die Rahmenbedingungen (Constraints) für eine neue Tabelle fest.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.6;">-- Erstellen der Tabelle "Kunden"
CREATE TABLE kunden (
    -- Spaltenname | Datentyp | Constraints
    kunden_id INT PRIMARY KEY,
    vorname VARCHAR(50) NOT NULL,
    nachname VARCHAR(50) NOT NULL,
    email VARCHAR(100) UNIQUE,
    geburtsdatum DATE,
    ist_aktiv BOOLEAN DEFAULT TRUE
);</code></pre></div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Bestehende Strukturen verändern (ALTER & DROP)</h3>
<p>Manchmal ändern sich die Anforderungen im Laufe eines Softwareprojekts. Für diese Fälle bietet SQL Werkzeuge, um das Schema nachträglich anzupassen, ohne die eigentlichen Daten zu verlieren.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #3498db; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.6;">-- Eine neue Spalte hinzufügen
ALTER TABLE kunden ADD telefonnummer VARCHAR(30);

-- Den Datentyp einer bestehenden Spalte ändern
ALTER TABLE kunden ALTER COLUMN nachname TYPE VARCHAR(100);

-- Eine Spalte komplett entfernen
ALTER TABLE kunden DROP COLUMN telefonnummer;</code></pre></div>

<div style="background: #fef2f2; padding: 1.2rem; border-left: 4px solid #e74c3c; margin: 2rem 0; border-radius: 4px; color: #c0392b; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
    <strong>🚨 Gefahr! Der DROP-Befehl:</strong> Der Befehl <code>DROP TABLE kunden;</code> löscht die <strong>gesamte Tabelle inklusive aller darin enthaltenen Daten</strong> unwiderruflich aus der Datenbank. Er ist mit extremer Vorsicht zu genießen!
</div>', '', 'article', 'published', 12, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('l6zbun54sj9gzbpw07o', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4F10 - Kapitel 6', '', '[
    {
        "chapter": "Kapitel 6",
        "question": "Wie wird beim Anlegen eines Anlagenstammsatzes die Anlagennummer zugeordnet?",
        "type": "radio",
        "options": {
            "A": "Die Anlagennummer wird über die Anlagenklasse zugeordnet.",
            "B": "Die Anlagennummer wird manuell vergeben.",
            "C": "Die Anlagennummer wird über den Buchungskreis zugeordnet.",
            "D": "Die Anlagennummer wird über das Sachkonto abgeleitet."
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 6",
        "question": "Wozu dient der Kontenfindungsschlüssel für die Anlage?",
        "type": "radio",
        "options": {
            "A": "Er verbindet die Anlage mit dem Sachkonto (Abstimmkonto).",
            "B": "Er berechnet die monatliche Abschreibung.",
            "C": "Er definiert die voraussichtliche Nutzungsdauer.",
            "D": "Er verknüpft die Anlage zwingend mit einer Kostenstelle."
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 6",
        "question": "Jede Anlage gehört einem Buchungskreis an. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 6",
        "question": "Eine Bewegungsart gibt an, an welcher Stelle im Anlagengitter die Buchung aufgeführt wird. Entscheiden Sie, ob diese Aussage richtig oder falsch ist.",
        "type": "radio",
        "options": {
            "A": "Richtig",
            "B": "Falsch"
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 6",
        "question": "Welche Methoden stehen für das Buchen von Zugängen in der Anlagenbuchhaltung zur Verfügung? (Mehrere Antworten möglich)",
        "type": "checkbox",
        "options": {
            "A": "Ein Anlagenzugang aus einem Kauf gegen Kreditor.",
            "B": "Ein Anlagenkauf mit automatischer Gegenbuchung.",
            "C": "Abrechnung ausschließlich über das Kassenbuch.",
            "D": "Automatische Buchung bei der Warenausgabe im Vertrieb."
        },
        "correct": [
            "A",
            "B"
        ],
        "link": "\\/module?id=s4f10"
    },
    {
        "chapter": "Kapitel 6",
        "question": "Wozu dient der Asset Explorer?",
        "type": "radio",
        "options": {
            "A": "Er bietet eine Übersicht über die Aktivitäten für eine Anlage nach Bewertungsbereich und Geschäftsjahr (Planwerte, gebuchte Bewegungen, Abschreibungen etc.).",
            "B": "Er dient ausschließlich zur Anlage und Löschung neuer Buchungskreise in der Anlagenbuchhaltung.",
            "C": "Er ist ein Tool zur Verwaltung von Mitarbeiterzugriffen auf Anlagegüter.",
            "D": "Er berechnet automatisch den Verkaufspreis einer Anlage für den externen Markt."
        },
        "correct": [
            "A"
        ],
        "link": "\\/module?id=s4f10"
    },
