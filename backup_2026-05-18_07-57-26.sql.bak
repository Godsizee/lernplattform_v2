                    </tr>
                    <tr style="font-weight: bold; background-color: #f0f0f0;">
                        <td style="padding: 8px;">Summe des Vermögens</td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px; text-align: right;">20.000.000,00</td>
                    </tr>

                    <!-- SCHULDEN -->
                     <tr style="background-color: #f8f9fa;">
                        <td colspan="4" style="padding: 16px 8px 8px 8px; font-weight: bold; color: #c0392b;">B. Schulden (Verbindlichkeiten)</td>
                    </tr>
                    <tr>
                        <td colspan="4" style="padding: 8px; font-weight: bold;">I. Langfristige Verbindlichkeiten</td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">1. Hypothekendarlehen der Leverkusener Kreditbank</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px; text-align: right;">4.106.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">2. Darlehen der Deutschen Bank, Köln</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px; text-align: right;">1.204.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                    <tr>
                        <td colspan="4" style="padding: 8px; font-weight: bold;">II. Kurzfristige Verbindlichkeiten</td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">1. Verbindlichkeiten a. LL</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 24px;">Heyn GmbH, Münster</td>
                        <td style="padding: 4px 8px; text-align: right;">457.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 24px;">Jutta Hermanns e. Kffr., Rheine</td>
                        <td style="padding: 4px 8px; text-align: right; border-bottom: 1px solid #ccc;">233.000,00</td>
                        <td style="padding: 4px 8px; text-align: right; border-bottom: 1px solid #ccc;">690.000,00</td>
                        <td style="padding: 4px 8px;"></td>
                    </tr>
                    <tr style="font-weight: bold; background-color: #f0f0f0;">
                        <td style="padding: 8px;">Summe der Schulden</td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px; text-align: right;">6.000.000,00</td>
                    </tr>

                    <!-- REINVERMÖGEN -->
                    <tr style="background-color: #f8f9fa;">
                        <td colspan="4" style="padding: 16px 8px 8px 8px; font-weight: bold; color: #c0392b;">C. Ermittlung des Eigenkapitals</td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">Summe des Vermögens</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px; text-align: right;">20.000.000,00</td>
                    </tr>
                     <tr>
                        <td style="padding: 4px 8px;">- Summe der Schulden</td>
                        <td style="padding: 4px 8px;"></td>
                        <td style="padding: 4px 8px; border-bottom: 1px solid #000;"></td>
                        <td style="padding: 4px 8px; text-align: right; border-bottom: 1px solid #000;">6.000.000,00</td>
                    </tr>
                    <tr style="font-weight: bold; background-color: #e8f4f8;">
                        <td style="padding: 8px;">= Eigenkapital (Reinvermögen)</td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px;"></td>
                        <td style="padding: 8px; text-align: right;">14.000.000,00</td>
                    </tr>
                </table>
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>4. Erfolgsermittlung durch Eigenkapitalvergleich</h3>
            <p>Der Erfolg (Gewinn oder Verlust) lässt sich durch den Vergleich des Eigenkapitals am Anfang und am Ende des Jahres ermitteln (§ 4 Abs. 1 EStG).</p>
            <p><strong>Privatentnahmen</strong> mindern das Kapital, sind aber kein betrieblicher Aufwand -> sie werden wieder hinzugerechnet.<br>
            <strong>Privateinlagen</strong> erhöhen das Kapital, sind aber kein betrieblicher Ertrag -> sie werden abgezogen.</p>

            <div style="background: #fff8e1; padding: 1.5rem; border-radius: 8px; border: 1px solid #ffeebb;">
                <h4 style="margin-top:0;">Beispielrechnung (Fortsetzung Möbelwerke):</h4>
                <table style="width: 100%; border-collapse: collapse;">
                    <tr>
                        <td style="padding: 4px 0;">Eigenkapital am 31.12. (Schluss)</td>
                        <td style="text-align: right;">14.000.000,00 €</td>
                    </tr>
                    <tr style="border-bottom: 1px solid #ccc;">
                        <td style="padding: 4px 0;">- Eigenkapital am 01.01. (Anfang)</td>
                        <td style="text-align: right;">12.200.000,00 €</td>
                    </tr>
                    <tr>
                        <td style="padding: 8px 0; font-weight: bold;">= Erhöhung des Eigenkapitals</td>
                        <td style="text-align: right; font-weight: bold;">1.800.000,00 €</td>
                    </tr>
                    <tr>
                        <td style="padding: 4px 0;">+ Privatentnahmen (z.B. Sportwagen, Lebenshaltung)</td>
                        <td style="text-align: right; color: var(--accent-color);">+ 60.000,00 €</td>
                    </tr>
                    <tr style="border-bottom: 1px solid #ccc;">
                        <td style="padding: 4px 0;">- Privateinlagen (z.B. geerbtes Grundstück eingebracht)</td>
                        <td style="text-align: right; color: var(--secondary-color);">- 250.000,00 €</td>
                    </tr>
                    <tr style="background-color: #fceceb; font-weight: bold; font-size: 1.1em;">
                        <td style="padding: 8px;">= Gewinn zum 31. Dezember</td>
                        <td style="text-align: right; padding: 8px;">1.610.000,00 €</td>
                    </tr>
                </table>
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

            <h3>5. Verzinsung des Eigenkapitals (Rentabilität)</h3>
            <p>Diese Kennzahl zeigt, ob sich der Kapitaleinsatz im Unternehmen stärker lohnt als eine langfristige Kapitalanlage (z.B. am Kapitalmarkt mit 2-5%).</p>

            <div style="background: #e8f4f8; padding: 1rem; border-radius: 6px; text-align: center; margin: 1rem 0;">
                <code>Rentabilität = (Jahresgewinn * 100) / Durchschnittliches Eigenkapital</code>
            </div>

            <p><strong>Berechnung für Möbelwerke Lutz Weise:</strong><br>
            Ø Eigenkapital = (12.200.000 + 14.000.000) / 2 = 13.100.000 €<br><br>
            Rentabilität = (1.610.000 € * 100) / 13.100.000 € = <strong>12,29 %</strong></p>
            <p><em>Bewertung: Die Verzinsung ist deutlich höher als bei einer Bankanlage. Das unternehmerische Risiko hat sich gelohnt.</em></p>
        ', '', 'article', 'published', 24, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lry6iiuizj5b78roycg', 's7lwkngmjvwoajhz3cf', 'u5ilhtdcn9ycti9tbmc', 'Qualitätssicherung: Automatische Tests', '<h3>1. Warum automatisiert testen?</h3>
<p>Automatische Softwaretests sind das Rückgrat jeder professionellen Anwendung. Sie automatisieren wiederkehrende Prüfprozesse, sparen bei Code-Änderungen massiv Zeit und verhindern, dass alte Fehler ("Regressionen") unbemerkt wieder auftreten.</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">🔬 Unit-Tests</h4>
        <p style="color: #555; font-size: 0.9rem;">Testen die kleinstmögliche Einheit (z.B. eine einzelne Methode). Sie sind extrem schnell und isoliert von äußeren Systemen (keine echte Datenbank).</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8fcfd; border-left: 4px solid #3498db; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #2980b9;">🔗 Integrationstests</h4>
        <p style="color: #555; font-size: 0.9rem;">Prüfen, ob verschiedene Module (oder z.B. die Anwendung und die Datenbank) korrekt <em>zusammenarbeiten</em>.</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fef2f2; border-left: 4px solid #e74c3c; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #c0392b;">🌍 System- & Akzeptanztests</h4>
        <p style="color: #555; font-size: 0.9rem;">Validieren die gesamte, fertig gebaute Anwendung aus Sicht des Endnutzers (Oft via QA-Team oder Tools wie Selenium).</p>
    </div>
</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>2. Das Arrange-Act-Assert (AAA) Prinzip</h3>
<p>Ein sauberer Unit-Test folgt immer diesem dreistufigen Muster, um maximale Lesbarkeit zu garantieren:</p>
<table style="width: 100%; border-collapse: collapse; margin-top: 1rem; box-shadow: 0 4px 15px rgba(0,0,0,0.05); font-size: 0.95rem; border-radius: 8px; overflow: hidden;">
    <thead>
        <tr style="background: linear-gradient(135deg, #2c3e50, #34495e); color: #fff;">
            <th style="padding: 15px; text-align: left; width: 25%;">Phase</th>
            <th style="padding: 15px; text-align: left; width: 75%;">Aktion</th>
        </tr>
    </thead>
    <tbody>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #2980b9;">1. Arrange (Vorbereiten)</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Testdaten und Objekte werden initialisiert. Der Anfangszustand wird hergestellt.</td>
        </tr>
        <tr>
            <td style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #d35400;">2. Act (Ausführen)</td>
            <td style="padding: 15px; border-bottom: 1px solid #eee; color: #333;">Die eigentliche Methode, die getestet werden soll, wird aufgerufen.</td>
        </tr>
        <tr style="background: #f8f9fa;">
            <td style="padding: 15px; font-weight: bold; color: #27ae60;">3. Assert (Prüfen)</td>
            <td style="padding: 15px; color: #333;">Das tatsächliche Ergebnis wird mit dem erwarteten Ergebnis verglichen.</td>
        </tr>
    </tbody>
</table>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Praxis mit JUnit 5 in Maven</h3>
<p>Um Unit-Tests in einem Java-Projekt zu schreiben, wird meistens das Framework <strong>JUnit</strong> verwendet. In einem Maven-Projekt fügen wir dazu folgende Abhängigkeit in unsere <code>pom.xml</code> ein:</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #f39c12; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">&lt;dependencies&gt;
    &lt;dependency&gt;
        &lt;groupId&gt;org.junit.jupiter&lt;/groupId&gt;
        &lt;artifactId&gt;junit-jupiter&lt;/artifactId&gt;
        &lt;version&gt;5.11.0&lt;/version&gt;
        &lt;scope&gt;test&lt;/scope&gt;
    &lt;/dependency&gt;
&lt;/dependencies&gt;</code></pre></div>

<h4>Einen Test schreiben</h4>
<p>Wir testen eine simple Hilfsklasse <code>MathUtility</code>, welche Methoden zum Addieren und Multiplizieren anbietet.</p>

<div class="code-block" style="background: #1e1e1e; color: #d4d4d4; padding: 1.5rem; border-radius: 8px; overflow-x: auto; box-shadow: inset 0 2px 4px rgba(0,0,0,0.3); border-left: 4px solid #a972ff; margin: 1.5rem 0;"><pre style="margin: 0;"><code style="font-family: ''Fira Code'', Consolas, monospace; font-size: 0.95rem; line-height: 1.5;">import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.assertEquals;

public class MathUtilityTest {

    @Test // Annotation kennzeichnet diese Methode als Testfall
    public void testAdd() {
        // 1. Arrange
        double value1 = 5.5;
        double value2 = 4.5;
        
        // 2. Act
        double result = MathUtility.add(value1, value2);
        
        // 3. Assert (Erwarteter Wert, Tatsächlicher Wert)
        assertEquals(10.0, result, "Die Addition sollte 10.0 ergeben!");
    }

    @Test
    public void testMultiply() {
        // Arrange
        double v1 = 2.0;
        double v2 = 3.5;
        
        // Act
        double result = MathUtility.multiply(v1, v2);
        
        // Assert
        assertEquals(7.0, result, "Die Multiplikation sollte 7.0 ergeben!");
    }
}</code></pre></div>', '', 'article', 'published', 68, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('ls7ixf9ny7xutnvjux1', 'sa73hpuh8til90wnu0q', 'u5ilhtdcn9ycti9tbmc', 'Datenbanktheorie: Was ist ein Datenbanksystem?', '<h3>1. Die Grunddefinition</h3>
<p>Ein <strong>Datenbanksystem (DBS)</strong> besteht immer aus zwei Hauptkomponenten: Der eigentlichen Datenbasis (der Datenbank, DB) und der Software, die diese Daten verwaltet, dem Datenbankmanagementsystem (DBMS).</p>

<div style="background: #e8f4f8; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #3498db; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0,0,0,0.05); text-align: center; font-size: 1.2rem; font-weight: bold; color: #2c3e50;">
    DBS = DB (Daten) + DBMS (Verwaltungs-Software)
</div>

<h3>2. Probleme der frühen Datenverarbeitung</h3>
<p>Bevor es moderne relationale Datenbanken gab, wurden Daten meist in einfachen, voneinander isolierten Text- oder Binärdateien (Dateisystemen) gespeichert. Das führte zu massiven Problemen in Unternehmen:</p>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fef2f2; border-left: 4px solid #e74c3c; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #c0392b;">🔄 Datenredundanz</h4>
        <p style="color: #555; font-size: 0.9rem;">Die gleichen Daten (z. B. Adressen von Kunden) wurden mehrfach in verschiedenen Dateien gespeichert. Das verschwendet Speicherplatz und führt schnell zu Chaos.</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #fffaf0; border-left: 4px solid #f39c12; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #d35400;">⚠️ Dateninkonsistenz</h4>
        <p style="color: #555; font-size: 0.9rem;">Die direkte Folge von Redundanz: Ändert sich die Adresse eines Kunden, muss sie in allen Dateien geändert werden. Wird eine Datei vergessen, widersprechen sich die Daten (Inkonsistenz).</p>
    </div>
    <div style="border: 1px solid #eee; border-radius: 8px; padding: 1.5rem; background: #f8f9fa; border-left: 4px solid #7f8c8d; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <h4 style="margin-top:0; color: #34495e;">🔗 Datenabhängigkeit</h4>
        <p style="color: #555; font-size: 0.9rem;">Programme und Datenstrukturen waren starr miteinander verknüpft. Wenn sich das Format der Datei änderte, musste das gesamte Programm umgeschrieben werden.</p>
    </div>
</div>

<hr style="border: 0; border-top: 1px solid #eee; margin: 2rem 0;">

<h3>3. Die Lösung: Relationale Datenbanken</h3>
<p>Um diese Probleme zu beheben, wurden Datenbanksysteme entwickelt. Die Daten werden zentral gespeichert, von einer intelligenten Software verwaltet und Programme greifen nicht mehr direkt auf Dateien zu, sondern schicken standardisierte Abfragen (SQL) an das DBMS.</p>', '', 'article', 'published', 1, '2026-04-27 09:46:06', '2026-04-27 09:46:06');
INSERT INTO lessons (id, subjectId, authorId, title, content, contentRaw, type, status, sortOrder, createdAt, updatedAt) VALUES ('lsa3eegvlqsh19wido0', 'sciiifndcvaztls7lnh', 'u5ilhtdcn9ycti9tbmc', 'Quiz: S4H00 - Kapitel 8', '', '[
    {
        "chapter": 8,
        "question": "31. Welches sind die drei Säulen von SAP Activate?",
        "type": "checkbox",
        "options": {
            "A": "Methodik",
            "B": "Leistungsoptimierung",
            "C": "Geführte Konfiguration",
            "D": "SAP Best Practices"
        },
        "correct": [
            "A",
            "C",
            "D"
        ],
        "link": "s4h00.php#topic-intro"
    },
    {
        "chapter": 8,
        "question": "32. Welches sind die drei Implementierungsszenarien von SAP Activate?",
        "type": "checkbox",
        "options": {
            "A": "Systemkonvertierung",
            "B": "Neue Implementierung",
            "C": "Transformation der Landschaft",
            "D": "Datenbankmigration"
        },
        "correct": [
            "A",
            "B",
            "C"
        ],
